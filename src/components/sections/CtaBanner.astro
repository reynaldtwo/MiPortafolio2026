---
import Button from '../ui/Button.astro';

interface Props {
  title: string;
  primary: { label: string; href: string; target?: '_blank' | '_self' };
  secondary?: { label: string; href: string; target?: '_blank' | '_self' };
}

const { title, primary, secondary } = Astro.props;
const compact = !secondary;
---

<section class="section">
  <div class="container">
    <div class:list={['banner surface reveal', compact && 'is-compact']} data-reveal>
      <div class:list={[compact ? 'stack-3' : 'stack-4']}>
        <h2>{title}</h2>
        <div class:list={['row', compact && 'is-compact']}>
          <Button href={primary.href} target={primary.target} variant={compact ? 'link' : 'primary'}>
            {primary.label}
          </Button>
          {
            secondary && (
              <Button href={secondary.href} target={secondary.target} variant="secondary">
                {secondary.label}
              </Button>
            )
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .banner {
    padding: var(--surface-padding-lg);
    position: relative;
    overflow: hidden;
  }

  .banner.is-compact {
    padding: var(--surface-padding);
  }

  .banner::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 10% 15%, color-mix(in srgb, var(--accent) 16%, transparent), transparent 38%),
      linear-gradient(120deg, color-mix(in srgb, var(--accent) 10%, transparent), transparent 52%, color-mix(in srgb, var(--accent-2) 10%, transparent));
    opacity: 0.68;
    pointer-events: none;
  }

  .banner.is-compact::before {
    background:
      radial-gradient(circle at 12% 14%, color-mix(in srgb, var(--accent) 12%, transparent), transparent 44%),
      linear-gradient(120deg, color-mix(in srgb, var(--accent) 8%, transparent), transparent 60%, color-mix(in srgb, var(--accent-2) 6%, transparent));
    opacity: 0.42;
    pointer-events: none;
  }

  .banner::after {
    content: '';
    position: absolute;
    inset: 0;
    border: 1px solid color-mix(in srgb, var(--accent) 18%, transparent);
    border-radius: var(--radius-lg);
    opacity: 0.34;
    pointer-events: none;
  }

  .banner.is-compact::after {
    opacity: 0.22;
    pointer-events: none;
  }

  .row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    position: relative;
    z-index: 1;
    align-items: center;
  }

  .row.is-compact {
    gap: var(--space-2);
  }

  h2 {
    position: relative;
    z-index: 1;
    max-width: 24ch;
  }

  .banner.is-compact h2 {
    max-width: 20ch;
    font-size: clamp(1.45rem, 2.2vw, 1.85rem);
  }

  @media (max-width: 680px) {
    .row {
      display: grid;
      grid-template-columns: 1fr;
    }

    .row :global(.btn) {
      width: 100%;
    }
  }
</style>
