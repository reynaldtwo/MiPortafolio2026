---
import type { Locale } from '../../types/content';
import Button from '../ui/Button.astro';
import Badge from '../ui/Badge.astro';
import TechConstellation from './TechConstellation.astro';

interface Highlight {
  value: string;
  label: string;
}

interface Props {
  locale: Locale;
  title: string;
  subline: string;
  paragraph: string;
  chips: string[];
  primaryCta: { label: string; href: string };
  secondaryCta: { label: string; href: string };
  panelTitle?: string;
  constellationTitle?: string;
  highlights?: Highlight[];
}

const {
  locale,
  title,
  subline,
  paragraph,
  chips,
  primaryCta,
  secondaryCta,
  panelTitle = '',
  constellationTitle = '',
  highlights = [],
} = Astro.props;
---

<section class="section hero-section">
  <div class="container hero-grid">
    <div class="hero-copy stack-5 reveal" data-reveal>
      <p class="eyebrow">{subline}</p>
      <h1>{title}</h1>
      <p class="hero-paragraph">{paragraph}</p>

      <div class="hero-cta">
        <Button href={primaryCta.href}>{primaryCta.label}</Button>
        <Button href={secondaryCta.href} variant="secondary">
          {secondaryCta.label}
        </Button>
      </div>

      <div class="chip-row proof-row">
        {chips.map((chip, index) => (
          <span style={`--delay:${index * 110}ms`}>
            <Badge>{chip}</Badge>
          </span>
        ))}
      </div>
    </div>

    <aside class="hero-panel reveal" data-reveal>
      <TechConstellation title={constellationTitle} locale={locale} />

      <div class="stats-shell surface">
        <div class="panel-head">
          <p>{panelTitle}</p>
          <span aria-hidden="true">01</span>
        </div>

        <div class="panel-grid">
          {highlights.map((item) => (
            <article class="stat">
              <p class="value">{item.value}</p>
              <p class="label">{item.label}</p>
            </article>
          ))}
        </div>
      </div>
    </aside>
  </div>
</section>

<style>
  .hero-section {
    padding-top: var(--section-space-first);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    align-items: start;
    gap: var(--layout-gap-hero);
  }

  .eyebrow {
    display: inline-flex;
    width: fit-content;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 600;
    color: color-mix(in srgb, var(--accent-2) 24%, var(--text-0) 76%);
    border: 1px solid color-mix(in srgb, var(--accent-2) 52%, transparent);
    border-radius: var(--radius-pill);
    padding: 0.25rem 0.72rem;
    background: color-mix(in srgb, var(--accent-2) 18%, transparent);
  }

  :global([data-theme='light']) .eyebrow {
    color: #fbf8f2;
    font-weight: 600;
    letter-spacing: 0.025em;
    border-color: color-mix(in srgb, var(--accent-strong) 54%, rgba(255, 255, 255, 0.18));
    background: linear-gradient(
      140deg,
      #0d1d4a 0%,
      #1748b6 56%,
      #0c8a92 148%
    );
    box-shadow:
      0 20px 34px rgba(13, 29, 74, 0.18),
      0 8px 18px rgba(12, 138, 146, 0.12),
      inset 0 1px 0 rgba(255, 255, 255, 0.16);
  }

  .hero-paragraph {
    max-width: 64ch;
  }

  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .proof-row > span {
    opacity: 0;
    transform: translateY(5px);
    animation: proof-in 560ms var(--motion-ease) forwards;
    animation-delay: var(--delay);
  }

  .hero-panel {
    display: grid;
    gap: var(--space-4);
  }

  .stats-shell {
    padding: var(--surface-padding-sm);
    display: grid;
    gap: var(--space-4);
    position: relative;
    overflow: hidden;
  }

  :global([data-theme='light']) .stats-shell {
    background:
      radial-gradient(circle at 16% 18%, rgba(255, 255, 255, 0.8), transparent 28%),
      linear-gradient(160deg, rgba(255, 255, 255, 0.99), rgba(246, 249, 253, 0.94) 58%, rgba(238, 244, 250, 0.96) 100%),
      var(--card);
    border-color: color-mix(in srgb, var(--stroke) 96%, rgba(255, 255, 255, 0.82));
    box-shadow:
      var(--shadow-soft),
      inset 0 1px 0 rgba(255, 255, 255, 0.88),
      inset 0 -1px 0 rgba(16, 29, 47, 0.04);
  }

  .stats-shell::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(
      110deg,
      color-mix(in srgb, var(--accent) 16%, transparent),
      transparent 54%,
      color-mix(in srgb, var(--accent-2) 14%, transparent)
    );
  }

  .panel-head,
  .panel-grid {
    position: relative;
    z-index: 1;
  }

  .panel-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .panel-head p {
    color: var(--text-0);
    font-weight: 600;
  }

  .panel-head span {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--muted);
  }

  .panel-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-3);
  }

  .stat {
    padding: var(--space-4);
    border-radius: var(--radius-md);
    border: 1px solid var(--stroke);
    background: color-mix(in srgb, var(--card) 92%, transparent);
  }

  :global([data-theme='light']) .stat {
    background:
      radial-gradient(circle at 18% 18%, rgba(255, 255, 255, 0.76), transparent 28%),
      linear-gradient(160deg, rgba(255, 255, 255, 0.97), rgba(246, 249, 253, 0.9) 58%, rgba(239, 244, 248, 0.92) 100%);
    border-color: color-mix(in srgb, var(--stroke) 92%, rgba(255, 255, 255, 0.8));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.78),
      0 10px 18px rgba(15, 28, 46, 0.04);
  }

  .value {
    margin: 0;
    color: var(--text-0);
    font-family: var(--font-heading);
    font-size: 1.25rem;
    line-height: 1.1;
  }

  .label {
    margin-top: var(--space-1);
    font-size: 0.84rem;
  }

  @keyframes proof-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (min-width: 1440px) {
    .hero-grid {
      grid-template-columns: 0.94fr 1.06fr;
      gap: var(--layout-gap-hero);
    }
  }

  @media (max-width: 960px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 680px) {
    .hero-cta {
      display: grid;
      grid-template-columns: 1fr;
    }

    .hero-cta :global(.btn) {
      width: 100%;
    }
  }

  @media (max-width: 560px) {
    .panel-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .proof-row > span {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
