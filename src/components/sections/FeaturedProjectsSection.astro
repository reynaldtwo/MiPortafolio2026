---
import Card from '../ui/Card.astro';
import Badge from '../ui/Badge.astro';
import Button from '../ui/Button.astro';
import type { Locale, Project } from '../../types/content';
import type { I18nDictionary } from '../../data/i18n';
import { translateText } from '../../utils/projects';

interface Props {
  title: string;
  projects: Project[];
  locale: Locale;
  dict: I18nDictionary;
  projectsHref: string;
}

const { title, projects, locale, dict, projectsHref } = Astro.props;
---

<section class="section">
  <div class="container stack-5">
    <div class="section-head">
      <h2 class="section-title reveal" data-reveal>{title}</h2>
      <Button href={projectsHref} variant="link">
        {dict.ctas.seeAllProjects}
      </Button>
    </div>
    <div class="grid-3">
      {
        projects.map((project) => (
          <Card>
            <div class="stack-4 reveal" data-reveal>
              <h3>{translateText(project.title, locale)}</h3>
              <p>{translateText(project.oneLiner, locale)}</p>
              <div class="chip-row">
                {project.categories.map((category) => <Badge>{dict.filters[category]}</Badge>)}
              </div>
              <div>
                <strong>{dict.labels.impact}</strong>
                <ul>
                  {project.impact.slice(0, 2).map((entry) => <li>{translateText(entry, locale)}</li>)}
                </ul>
              </div>
              <div class="card-cta">
                <Button href={`/${locale}/projects#${project.links.caseStudyAnchor}`} variant="secondary">
                  {dict.links.readCaseStudy}
                </Button>
              </div>
            </div>
          </Card>
        ))
      }
    </div>
  </div>
</section>

<style>
  .section-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  h3 {
    font-size: 1.16rem;
  }

  strong {
    display: block;
    margin-bottom: var(--space-2);
    font-size: 0.88rem;
    color: var(--text-0);
  }

  ul {
    margin: 0;
    padding-left: 1.1rem;
    color: var(--text-1);
    display: grid;
    gap: 0.35rem;
  }

  .card-cta {
    padding-top: var(--space-2);
  }

  li {
    font-size: 0.93rem;
  }
</style>
