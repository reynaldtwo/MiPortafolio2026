---
import Card from '../ui/Card.astro';

interface Pillar {
  title: string;
  points: string[];
}

interface Props {
  title: string;
  items: Pillar[];
}

const { title, items } = Astro.props;
---

<section class="section">
  <div class="container">
    <h2 class="section-title reveal" data-reveal>{title}</h2>
    <div class="grid-3">
      {
        items.map((item, index) => (
          <Card>
            <div class="stack-4 reveal" data-reveal>
              <p class="pill-index">0{index + 1}</p>
              <h3>{item.title}</h3>
              <ul>
                {item.points.map((point) => <li>{point}</li>)}
              </ul>
            </div>
          </Card>
        ))
      }
    </div>
  </div>
</section>

<style>
  .pill-index {
    width: fit-content;
    border-radius: var(--radius-pill);
    border: 1px solid color-mix(in srgb, var(--accent) 40%, transparent);
    color: var(--accent-2);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    padding: 0.2rem 0.56rem;
    background: color-mix(in srgb, var(--accent) 12%, transparent);
  }

  ul {
    margin: 0;
    padding-left: 1.1rem;
    color: var(--text-1);
    display: grid;
    gap: var(--space-2);
  }
</style>
