---
import Badge from '../ui/Badge.astro';
import type { I18nDictionary } from '../../data/i18n';
import { siteConfig } from '../../data/site';
import { siGithub, siGmail, siWhatsapp } from 'simple-icons';
import linkedinIcon from '../../../Recursos/linkedin.png';


interface Props {
  dict: I18nDictionary;
}

const { dict } = Astro.props;
const isEs = dict.localeCode === 'es';

const proofChips = isEs
  ? ['Remoto', 'Internacional', 'Fullstack']
  : ['Remote', 'International', 'Fullstack'];

const contactButtons = [
  {
    label: 'Email',
    href: siteConfig.contact.email,
    type: 'simple',
    icon: siGmail.path,
    brand: '#ea4335',
  },
  {
    label: 'WhatsApp',
    href: siteConfig.contact.whatsapp,
    type: 'simple',
    icon: siWhatsapp.path,
    brand: '#25d366',
  },
  {
    label: 'LinkedIn',
    href: siteConfig.contact.linkedin,
    type: 'linkedin',
    brand: '#0a66c2',
  },
  {
    label: 'GitHub',
    href: siteConfig.contact.github,
    type: 'simple',
    icon: siGithub.path,
    brand: '#8b949e',
  },
];
---

<section class="section contact-hero">
  <div class="container contact-stack">
    <div class="hero-shell surface reveal" data-reveal>
      <div class="hero-content stack-6">
        <div class="stack-4">
          <h1 class="text-center">{dict.contact.hero.title}</h1>
          <p class="section-subtitle text-center">{dict.contact.hero.subline}</p>
        </div>


        <div class="contact-actions-grid">
          {
            contactButtons.map((btn) => (
              <a
                href={btn.href}
                target="_blank"
                rel="noreferrer noopener"
                class="contact-btn-premium"
                style={`--brand: ${btn.brand}`}
              >
                <span class="btn-icon">
                  {btn.type === 'linkedin' ? (
                    <img src={linkedinIcon.src} alt="" loading="lazy" decoding="async" style="width: 1.25rem; height: 1.25rem;" />
                  ) : (
                    <svg viewBox="0 0 24 24" fill="currentColor">
                      <path d={btn.icon} />
                    </svg>
                  )}
                </span>

                <span class="btn-label">{btn.label}</span>
              </a>
            ))
          }
        </div>
      </div>
    </div>

    <!-- Disponibilidad integrada al final -->
    <div class="availability-bar surface reveal" data-reveal>
      <div class="availability-info">
        <h3>{dict.labels.availability}</h3>
        <p>{dict.contact.availability.text}</p>
      </div>
      <div class="chip-row">
        {dict.contact.availability.chips.map((chip) => <Badge>{chip}</Badge>)}
      </div>
    </div>
  </div>
</section>

<style>
  .contact-hero {
    padding-top: var(--section-space-first);
    padding-bottom: var(--section-space);
  }

  .hero-shell {
    position: relative;
    overflow: hidden;
    padding: var(--space-8) var(--space-6);
    display: flex;
    justify-content: center;
    border-radius: var(--radius-lg);

  }

  :global([data-theme='light']) .hero-shell {
    background:
      radial-gradient(circle at 50% 0%, rgba(255, 255, 255, 0.8), transparent 40%),
      linear-gradient(160deg, rgba(255, 255, 255, 0.99), rgba(246, 249, 253, 0.94) 54%, rgba(238, 244, 250, 0.96) 100%),
      var(--card);
    border-color: color-mix(in srgb, var(--stroke) 96%, rgba(255, 255, 255, 0.82));
    box-shadow:
      var(--shadow-soft),
      inset 0 1px 0 rgba(255, 255, 255, 0.88),
      inset 0 -1px 0 rgba(16, 29, 47, 0.04);
  }

  .hero-shell::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 10% 10%, color-mix(in srgb, var(--accent) 15%, transparent), transparent 30%),
      radial-gradient(circle at 90% 90%, color-mix(in srgb, var(--accent-2) 15%, transparent), transparent 30%);
    pointer-events: none;
  }

  .hero-content {
    width: 100%;
    max-width: 800px;
    position: relative;
    z-index: 1;
  }

  .contact-stack {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .contact-proof {
    gap: var(--cluster-gap);
  }

  .proof-chip {
    padding: 0.34rem 0.82rem;
    border-radius: var(--radius-pill);
    border: 1px solid var(--stroke);
    background: color-mix(in srgb, var(--card) 90%, transparent);
    color: var(--card-text-0);
    font-size: 0.88rem;
    font-weight: 600;
  }

  .contact-actions-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
    margin-top: var(--space-2);
  }

  .contact-btn-premium {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: flex-start;
    gap: var(--space-4);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-lg);
    background: var(--card);
    border: 1px solid var(--stroke);
    color: var(--text-0);
    text-decoration: none;
    transition: all var(--motion-fast) var(--motion-ease);
  }

  .contact-btn-premium:hover {
    transform: translateY(-4px);
    border-color: var(--brand);
    background: color-mix(in srgb, var(--brand) 8%, var(--card));
    box-shadow: 0 10px 20px -10px color-mix(in srgb, var(--brand) 40%, transparent);
  }

  .btn-icon {
    width: 1.75rem;
    height: 1.75rem;
    display: grid;
    place-items: center;
    color: var(--brand);
    flex-shrink: 0;
  }

  .btn-icon svg {
    width: 1.25rem;
    height: 1.25rem;
  }

  .btn-label {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--text-1);
    transition: color var(--motion-fast);
  }

  .contact-btn-premium:hover .btn-label {
    color: var(--text-0);
  }

  .availability-bar {
    padding: var(--space-6) var(--space-8);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    border-radius: var(--radius-lg);

  }

  .availability-info h3 {
    font-size: 1rem;
    margin-bottom: var(--space-1);
  }

  .availability-info p {
    color: var(--text-1);
    font-size: 0.95rem;
    margin: 0;
  }

  @media (max-width: 768px) {
    .contact-actions-grid {
      grid-template-columns: 1fr;
    }
    
    .availability-bar {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-5);
    }
  }

  @media (max-width: 480px) {
    .contact-actions-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
