---
import Button from '../ui/Button.astro';
import type { I18nDictionary } from '../../data/i18n';
import { siteConfig } from '../../data/site';

interface Props {
  dict: I18nDictionary;
}

const { dict } = Astro.props;
const isEs = dict.localeCode === 'es';

const proofChips = isEs
  ? ['Remoto', 'Internacional', 'WhatsApp-ready', 'Flutter-first']
  : ['Remote', 'International', 'WhatsApp-ready', 'Flutter-first'];

const panelKicker = isEs ? 'Canal recomendado según contexto' : 'Recommended channel by context';
const panelRows = [
  {
    title: 'WhatsApp',
    detail: isEs ? 'Contacto ágil para primeras conversaciones y coordinación rápida.' : 'Fast first contact and quick coordination.',
    brand: '#25d366',
  },
  {
    title: 'Email',
    detail: isEs ? 'Mejor para alcance, propuesta y siguientes pasos con claridad.' : 'Best for scope, proposal, and clear next steps.',
    brand: '#ea4335',
  },
  {
    title: isEs ? 'LinkedIn + GitHub' : 'LinkedIn + GitHub',
    detail: isEs ? 'Contexto profesional y evidencia técnica en paralelo.' : 'Professional context and technical proof side by side.',
    brand: '#2f7df6',
  },
];
---

<section class="section contact-hero">
  <div class="container">
    <div class="hero-shell surface">
      <div class="hero-copy stack-5 reveal" data-reveal>
        <div class="stack-4">
          <p class="hero-kicker">{panelKicker}</p>
          <h1>{dict.contact.hero.title}</h1>
          <p class="section-subtitle">{dict.contact.hero.subline}</p>
        </div>

        <div class="chip-row contact-proof">
          {proofChips.map((chip) => <span class="proof-chip">{chip}</span>)}
        </div>

        <div class="hero-actions">
          <Button href={siteConfig.contact.whatsapp} target="_blank">
            {isEs ? 'Abrir WhatsApp' : 'Open WhatsApp'}
          </Button>
          <Button href={siteConfig.contact.email} variant="secondary">
            {dict.ctas.email}
          </Button>
        </div>
      </div>

      <aside class="contact-panel reveal" data-reveal>
        <div class="panel-card">
          <div class="panel-head">
            <strong>{isEs ? 'Ruta de contacto' : 'Contact route'}</strong>
            <span>{siteConfig.timezoneLabel} | Managua</span>
          </div>

          <div class="panel-grid">
            {
              panelRows.map((item, index) => (
                <article class="panel-row" style={`--brand:${item.brand};--wave-delay:${index * 0.45}s`}>
                  <span class="panel-dot" aria-hidden="true"></span>
                  <div class="stack-4">
                    <h2>{item.title}</h2>
                    <p>{item.detail}</p>
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  .contact-hero {
    padding-top: var(--section-space-first);
  }

  .hero-shell {
    position: relative;
    overflow: hidden;
    padding: var(--surface-padding-lg);
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: var(--layout-gap);
    align-items: stretch;
  }

  :global([data-theme='light']) .hero-shell {
    background:
      radial-gradient(circle at 14% 16%, rgba(255, 255, 255, 0.8), transparent 26%),
      linear-gradient(160deg, rgba(255, 255, 255, 0.99), rgba(246, 249, 253, 0.94) 54%, rgba(238, 244, 250, 0.96) 100%),
      var(--card);
    border-color: color-mix(in srgb, var(--stroke) 96%, rgba(255, 255, 255, 0.82));
    box-shadow:
      var(--shadow-soft),
      inset 0 1px 0 rgba(255, 255, 255, 0.88),
      inset 0 -1px 0 rgba(16, 29, 47, 0.04);
  }

  .hero-shell::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 16% 18%, color-mix(in srgb, var(--accent) 20%, transparent), transparent 34%),
      radial-gradient(circle at 84% 72%, color-mix(in srgb, var(--accent-2) 18%, transparent), transparent 40%);
    pointer-events: none;
  }

  .hero-copy,
  .contact-panel {
    position: relative;
    z-index: 1;
  }

  .hero-kicker {
    width: fit-content;
    padding: 0.28rem 0.78rem;
    border-radius: var(--radius-pill);
    border: 1px solid color-mix(in srgb, var(--accent) 34%, var(--stroke));
    background: color-mix(in srgb, var(--accent) 18%, transparent);
    color: var(--card-text-0);
    font-family: var(--font-mono);
    font-size: 0.76rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .contact-proof {
    gap: var(--cluster-gap);
  }

  .proof-chip {
    padding: 0.34rem 0.72rem;
    border-radius: var(--radius-pill);
    border: 1px solid var(--stroke);
    background: color-mix(in srgb, var(--card) 90%, transparent);
    color: var(--card-text-0);
    font-size: 0.82rem;
    font-weight: 600;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .contact-panel {
    display: grid;
  }

  .panel-card {
    min-height: 100%;
    padding: var(--surface-padding);
    border-radius: var(--radius-lg);
    border: 1px solid color-mix(in srgb, var(--stroke) 88%, transparent);
    background:
      linear-gradient(145deg, color-mix(in srgb, var(--card) 94%, transparent), color-mix(in srgb, var(--bg-2) 76%, transparent)),
      radial-gradient(circle at 82% 18%, color-mix(in srgb, var(--accent) 16%, transparent), transparent 32%);
    box-shadow: var(--shadow-soft);
    display: grid;
    gap: var(--space-4);
  }

  :global([data-theme='light']) .panel-card {
    background:
      radial-gradient(circle at 14% 16%, rgba(255, 255, 255, 0.78), transparent 26%),
      linear-gradient(160deg, rgba(255, 255, 255, 0.99), rgba(246, 249, 253, 0.94) 58%, rgba(238, 244, 250, 0.96) 100%),
      var(--card);
    border-color: color-mix(in srgb, var(--stroke) 96%, rgba(255, 255, 255, 0.82));
    box-shadow:
      var(--shadow-soft),
      inset 0 1px 0 rgba(255, 255, 255, 0.88),
      inset 0 -1px 0 rgba(16, 29, 47, 0.04);
  }

  .panel-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .panel-head strong {
    color: var(--card-text-0);
    font-size: 0.98rem;
  }

  .panel-head span {
    color: var(--card-text-muted);
    font-family: var(--font-mono);
    font-size: 0.76rem;
  }

  .panel-grid {
    display: grid;
    gap: var(--space-3);
  }

  .panel-row {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-3);
    align-items: start;
    padding: var(--surface-padding-sm);
    border-radius: var(--radius-md);
    border: 1px solid color-mix(in srgb, var(--brand) 18%, var(--stroke));
    background: color-mix(in srgb, var(--card) 84%, transparent);
  }

  :global([data-theme='light']) .panel-row {
    background:
      radial-gradient(circle at 18% 18%, rgba(255, 255, 255, 0.76), transparent 28%),
      linear-gradient(160deg, rgba(255, 255, 255, 0.97), rgba(246, 249, 253, 0.9) 58%, rgba(239, 244, 248, 0.92) 100%);
    border-color: color-mix(in srgb, var(--brand) 16%, var(--stroke));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.8),
      0 10px 18px rgba(15, 28, 46, 0.04);
  }

  .panel-dot {
    position: relative;
    width: 0.78rem;
    height: 0.78rem;
    border-radius: 999px;
    margin-top: var(--space-1);
    background: var(--brand);
    box-shadow:
      0 0 0 6px color-mix(in srgb, var(--brand) 14%, transparent),
      0 0 18px color-mix(in srgb, var(--brand) 38%, transparent);
  }

  .panel-dot::before,
  .panel-dot::after {
    content: '';
    position: absolute;
    inset: 50%;
    width: 100%;
    height: 100%;
    border-radius: inherit;
    border: 1px solid color-mix(in srgb, var(--brand) 62%, transparent);
    transform: translate(-50%, -50%) scale(0.35);
    opacity: 0;
    animation: contact-wave 2.8s ease-out infinite;
    animation-delay: var(--wave-delay, 0s);
    pointer-events: none;
  }

  .panel-dot::after {
    animation-delay: calc(var(--wave-delay, 0s) + 1.4s);
  }

  .panel-row h2 {
    font-size: 1rem;
  }

  .panel-row p {
    color: var(--card-text-1);
    font-size: 0.92rem;
  }

  @keyframes contact-wave {
    0% {
      opacity: 0;
      transform: translate(-50%, -50%) scale(0.35);
    }

    18% {
      opacity: 0.75;
    }

    100% {
      opacity: 0;
      transform: translate(-50%, -50%) scale(3.35);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .panel-dot::before,
    .panel-dot::after {
      animation: none;
      opacity: 0;
    }
  }

  @media (max-width: 980px) {
    .hero-shell {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 680px) {
    .hero-actions {
      display: grid;
      grid-template-columns: 1fr;
    }

    .hero-actions :global(.btn) {
      width: 100%;
    }

    .panel-head {
      align-items: start;
      flex-direction: column;
    }
  }
</style>
