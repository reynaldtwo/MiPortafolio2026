---
import Card from '../ui/Card.astro';
import Badge from '../ui/Badge.astro';
import type { I18nDictionary } from '../../data/i18n';
import { siteConfig } from '../../data/site';

interface Props {
  dict: I18nDictionary;
}

const { dict } = Astro.props;
const links = [
  { key: 'LinkedIn', href: siteConfig.contact.linkedin, external: true },
  { key: 'GitHub', href: siteConfig.contact.github, external: true },
  { key: 'Play Store', href: siteConfig.contact.playStore, external: true },
  { key: 'Email', href: siteConfig.contact.email, external: false },
  { key: 'Schedule', href: siteConfig.contact.booking, external: true },
];
---

<section class="section">
  <div class="container stack-5">
    <h2 class="section-title reveal" data-reveal>{dict.contact.linksTitle}</h2>
    <div class="grid-3">
      {
        links.map((link, index) => (
          <Card>
            <a
              class="link-card reveal"
              data-reveal
              style={`--delay:${index * 70}ms`}
              href={link.href}
              target={link.external ? '_blank' : undefined}
              rel={link.external ? 'noreferrer noopener' : undefined}
            >
              <h3>{link.key}</h3>
              <p>{link.href}</p>
              <span class="jump" aria-hidden="true">Open</span>
            </a>
          </Card>
        ))
      }
    </div>
    <div class="stack-4 reveal" data-reveal>
      <h3>{dict.labels.availability}</h3>
      <p>{dict.contact.availability.text}</p>
      <div class="chip-row">
        {dict.contact.availability.chips.map((chip) => <Badge>{chip}</Badge>)}
      </div>
    </div>
  </div>
</section>

<style>
  .link-card {
    display: grid;
    gap: var(--space-2);
    transition-delay: var(--delay);
  }

  .link-card p {
    font-size: 0.88rem;
    word-break: break-all;
  }

  .jump {
    width: fit-content;
    border-radius: var(--radius-pill);
    border: 1px solid var(--stroke);
    padding: 0.12rem 0.48rem;
    font-size: 0.72rem;
    color: var(--card-text-muted);
    font-family: var(--font-mono);
  }
</style>
