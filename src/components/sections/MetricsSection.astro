---
import Card from '../ui/Card.astro';

interface Metric {
  value: string;
  label: string;
}

interface Props {
  title: string;
  metrics: Metric[];
}

const { title, metrics } = Astro.props;
---

<section class="section">
  <div class="container stack-5">
    <h2 class="section-title reveal" data-reveal>{title}</h2>
    <div class="grid-2 metrics-grid">
      {
        metrics.map((metric) => (
          <Card>
            <div class="metric reveal" data-reveal>
              <p class="value">{metric.value}</p>
              <p class="label">{metric.label}</p>
            </div>
          </Card>
        ))
      }
    </div>
  </div>
</section>

<style>
  .metrics-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .metric {
    display: grid;
    gap: var(--space-2);
  }

  .value {
    margin: 0;
    font-family: var(--font-heading);
    font-size: clamp(1.9rem, 2.8vw, 2.3rem);
    color: var(--text-0);
    line-height: 1;
  }

  .label {
    color: var(--text-1);
    margin: 0;
  }

  @media (max-width: 1080px) {
    .metrics-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .metrics-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
