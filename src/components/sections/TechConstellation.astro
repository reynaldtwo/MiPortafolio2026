---
import {
  resolveTechBrand,
  resolveTechDescription,
  resolveTechTone,
  techLinks,
  techNodes,
  type LinkKind,
  type TechNode,
} from '../../data/tech-stack';
import type { Locale } from '../../types/content';

interface Props {
  title?: string;
  locale?: Locale;
}

const nodeMap = new Map(techNodes.map((node) => [node.id, node]));
const links = techLinks
  .map((link) => ({ ...link, fromNode: nodeMap.get(link.from), toNode: nodeMap.get(link.to) }))
  .filter(
    (
      entry,
    ): entry is {
      from: string;
      to: string;
      kind: LinkKind;
      fromNode: TechNode;
      toNode: TechNode;
    } => Boolean(entry.fromNode && entry.toNode),
  );

const hubNode = nodeMap.get('microsoft');
const subhubNode = nodeMap.get('azure');
const showOrbitRings = false;
const showSectors = false;
const showNodeLabels = false;
const graphOffsetX = 3.2;
const graphOffsetY = 2;
const rootStyle = `--hub-x:${(hubNode?.x ?? 50) + graphOffsetX};--hub-y:${(hubNode?.y ?? 50) + graphOffsetY};--subhub-x:${(subhubNode?.x ?? 58) + graphOffsetX};--subhub-y:${(subhubNode?.y ?? 42) + graphOffsetY}`;
const sectors = [
  { id: 'frontend', x: 41, y: 20, w: 70, h: 28, tone: 'var(--accent-2)' },
  { id: 'automation', x: 21, y: 57, w: 28, h: 48, tone: 'var(--accent)' },
  { id: 'core', x: 52, y: 50, w: 34, h: 44, tone: 'var(--accent-2)' },
  { id: 'data', x: 37, y: 81, w: 44, h: 22, tone: 'var(--accent)' },
  { id: 'delivery', x: 79, y: 59, w: 24, h: 40, tone: 'var(--accent-2)' },
] as const;

const { title = '', locale = 'en' } = Astro.props;
const defaultNode = hubNode ?? techNodes[0];
---

<div class="constellation-shell" data-constellation-shell>
  <div class="constellation-card">
    <div class="constellation-topbar">
      {title ? <p class="constellation-title">{title}</p> : null}
    </div>

    <div
      class:list={['constellation', { 'labels-hidden': !showNodeLabels }]}
      data-constellation
      style={rootStyle}
      role="group"
      aria-label={title || (locale === 'es' ? 'Mapa de stack' : 'Stack map')}
    >
      {showSectors ? (
        <div class="sector-layer">
          {
            sectors.map((sector, index) => (
              <div
                class:list={['sector', `sector-${sector.id}`]}
                style={`--x:${sector.x + graphOffsetX};--y:${sector.y + graphOffsetY};--w:${sector.w};--h:${sector.h};--tone:${sector.tone};--delay:${220 + index * 90}ms`}
              ></div>
            ))
          }
        </div>
      ) : null}

      <svg class="link-layer" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
        {
          links.map((link, index) => (
            <line
              x1={link.fromNode.x + graphOffsetX}
              y1={link.fromNode.y + graphOffsetY}
              x2={link.toNode.x + graphOffsetX}
              y2={link.toNode.y + graphOffsetY}
              data-kind={link.kind}
              style={`--delay:${index * 90}ms`}
            />
          ))
        }
      </svg>

      <div class="hub-pulse" aria-hidden="true"></div>
      <div class="subhub-pulse" aria-hidden="true"></div>
      {showOrbitRings ? <div class="core-ring" aria-hidden="true"></div> : null}

      {
        techNodes.map((node, index) => (
          <button
            type="button"
            class:list={[
              'node',
              node.group ? `group-${node.group}` : undefined,
              node.priority ? `priority-${node.priority}` : undefined,
              {
                compact: node.size <= 34,
                hub: node.id === 'microsoft',
                subhub: node.id === 'azure',
                'mobile-hidden': !node.showOnMobile,
                'is-selected': node.id === defaultNode.id,
              },
            ]}
            data-tech-node
            data-tech-id={node.id}
            data-tech-label={node.label}
            data-tech-description={resolveTechDescription(node, locale)}
            aria-label={node.label}
            aria-pressed={node.id === defaultNode.id ? 'true' : 'false'}
            style={`--x:${node.x + graphOffsetX};--y:${node.y + graphOffsetY};--size:${node.size}px;--dx:${node.dx};--dy:${node.dy};--delay:${index * 80}ms;--brand:${resolveTechBrand(node)};--icon-tone-dark:${resolveTechTone(node, 'dark')};--icon-tone-light:${resolveTechTone(node, 'light')};--label-dx:${node.labelDx ?? 0}px;--label-dy:${node.labelDy ?? 0}px`}
          >
            <span class="glyph" aria-hidden="true">
              {node.iconSrc ? (
                <img src={node.iconSrc} alt="" loading="lazy" decoding="async" />
              ) : node.icon ? (
                <svg viewBox="0 0 24 24" role="img" aria-label={node.label}>
                  <path d={node.icon.path}></path>
                </svg>
              ) : (
                <strong>{node.fallback}</strong>
              )}
            </span>
            {showNodeLabels ? <span class="label">{node.label}</span> : null}
          </button>
        ))
      }
    </div>

    <article class="constellation-info" data-constellation-info aria-live="polite">
      <div class="constellation-info-head">
        <p class="kicker">{locale === 'es' ? 'Detalle del stack' : 'Stack detail'}</p>
        <strong data-constellation-info-title>{defaultNode.label}</strong>
      </div>
      <p data-constellation-info-description>{resolveTechDescription(defaultNode, locale)}</p>
    </article>
  </div>
</div>

<script is:inline>
  (() => {
    const shells = document.querySelectorAll('[data-constellation-shell]');

    shells.forEach((shell) => {
      const root = shell.querySelector('[data-constellation]');
      const title = shell.querySelector('[data-constellation-info-title]');
      const description = shell.querySelector('[data-constellation-info-description]');
      const nodes = Array.from(shell.querySelectorAll('[data-tech-node]'));
      let selectedNode = shell.querySelector('[data-tech-node].is-selected') ?? nodes[0];

      const setActiveNode = (nextNode) => {
        if (!nextNode || !title || !description) return;

        title.textContent = nextNode.dataset.techLabel ?? '';
        description.textContent = nextNode.dataset.techDescription ?? '';

        nodes.forEach((node) => {
          const isCurrent = node === nextNode;
          node.classList.toggle('is-selected', isCurrent);
          node.setAttribute('aria-pressed', isCurrent ? 'true' : 'false');
        });
      };

      window.requestAnimationFrame(() => root?.classList.add('is-ready'));
      if (selectedNode) setActiveNode(selectedNode);

      nodes.forEach((node) => {
        node.addEventListener('mouseenter', () => setActiveNode(node));
        node.addEventListener('focus', () => setActiveNode(node));
        node.addEventListener('click', () => {
          selectedNode = node;
          setActiveNode(node);
        });
      });

      root?.addEventListener('mouseleave', () => {
        if (selectedNode) setActiveNode(selectedNode);
      });

      root?.addEventListener('focusout', (event) => {
        if (!selectedNode) return;
        const nextTarget = event.relatedTarget;
        if (!(nextTarget instanceof Node) || !root?.contains(nextTarget)) {
          setActiveNode(selectedNode);
        }
      });
    });
  })();
</script>

<style>
  .constellation-shell {
    display: block;
  }

  .constellation-card {
    position: relative;
    display: grid;
    grid-template-rows: auto minmax(0, 1fr) auto;
    gap: var(--space-4);
    padding: var(--surface-padding-sm);
    border-radius: var(--radius-lg);
    border: 1px solid color-mix(in srgb, var(--stroke) 85%, transparent);
    isolation: isolate;
    background:
      radial-gradient(circle at 26% 18%, color-mix(in srgb, var(--accent) 16%, transparent), transparent 34%),
      radial-gradient(circle at 80% 78%, color-mix(in srgb, var(--accent-2) 16%, transparent), transparent 38%),
      linear-gradient(145deg, color-mix(in srgb, var(--card) 88%, transparent), color-mix(in srgb, var(--bg-2) 85%, transparent));
    overflow: hidden;
  }

  :global([data-theme='light']) .constellation-card {
    background:
      radial-gradient(circle at 18% 16%, rgba(10, 143, 166, 0.08), transparent 22%),
      radial-gradient(circle at 80% 72%, rgba(20, 95, 222, 0.12), transparent 30%),
      linear-gradient(160deg, rgba(255, 255, 255, 0.99), rgba(246, 249, 253, 0.94) 56%, rgba(238, 244, 250, 0.96) 100%);
    border-color: color-mix(in srgb, var(--stroke) 96%, rgba(255, 255, 255, 0.82));
    box-shadow:
      var(--shadow-soft),
      inset 0 1px 0 rgba(255, 255, 255, 0.88),
      inset 0 -1px 0 rgba(16, 29, 47, 0.04);
  }

  .constellation-card::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    background-image: radial-gradient(circle, color-mix(in srgb, var(--muted) 18%, transparent) 0.9px, transparent 1px);
    background-size: 22px 22px;
    opacity: 0.16;
    mask: linear-gradient(180deg, transparent, black 12%, black 88%, transparent);
    pointer-events: none;
  }

  .constellation-topbar {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 0.45rem;
  }

  .constellation-title {
    margin: 0;
    color: var(--text-0);
    font-size: 0.98rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    line-height: 1;
  }

  .constellation {
    position: relative;
    min-height: clamp(300px, 34vw, 370px);
    isolation: isolate;
    overflow: clip;
  }

  .constellation::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    background:
      radial-gradient(
        circle at calc(var(--hub-x) * 1%) calc(var(--hub-y) * 1%),
        color-mix(in srgb, var(--accent-2) 14%, transparent),
        transparent 24%
      ),
      radial-gradient(
        circle at calc(var(--subhub-x) * 1%) calc(var(--subhub-y) * 1%),
        color-mix(in srgb, var(--accent) 14%, transparent),
        transparent 18%
      ),
      radial-gradient(circle, color-mix(in srgb, var(--muted) 18%, transparent) 0.9px, transparent 1px);
    background-size: auto, auto, 22px 22px;
    opacity: 0.18;
    mask: linear-gradient(180deg, transparent, black 10%, black 90%, transparent);
    pointer-events: none;
  }

  .constellation-info {
    position: relative;
    z-index: 1;
    min-block-size: 5.35rem;
    padding: 0;
    display: grid;
    align-content: start;
    gap: 0.25rem;
  }

  .constellation-info > * {
    position: relative;
    z-index: 1;
  }

  .constellation-info-head {
    display: grid;
    gap: 0.2rem;
  }

  .kicker {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--accent-2) 26%, var(--text-0) 74%);
  }

  .constellation-info strong {
    color: var(--text-0);
    font-size: 1rem;
    line-height: 1.1;
  }

  .constellation-info p:last-child {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.45;
    color: var(--text-1);
    max-width: 46ch;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    overflow: hidden;
  }

  .sector-layer {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .sector {
    position: absolute;
    left: calc(var(--x) * 1%);
    top: calc(var(--y) * 1%);
    width: calc(var(--w) * 1%);
    height: calc(var(--h) * 1%);
    border-radius: 999px;
    transform: translate(-50%, -50%) scale(0.94);
    border: 1px solid color-mix(in srgb, var(--tone) 16%, transparent);
    background:
      radial-gradient(circle at 28% 28%, color-mix(in srgb, var(--tone) 10%, transparent), transparent 60%),
      linear-gradient(135deg, color-mix(in srgb, var(--card) 36%, transparent), transparent 78%);
    box-shadow:
      inset 0 0 0 1px color-mix(in srgb, var(--tone) 9%, transparent),
      0 24px 44px rgba(8, 19, 35, 0.05);
    opacity: 0;
    transition:
      opacity 820ms var(--motion-ease),
      transform 900ms var(--motion-ease);
  }

  .constellation.is-ready .sector {
    opacity: 0.82;
    transform: translate(-50%, -50%) scale(1);
    transition-delay: var(--delay);
  }

  .hub-pulse,
  .subhub-pulse {
    position: absolute;
    border-radius: 999px;
    pointer-events: none;
    z-index: 1;
    transform: translate(-50%, -50%);
  }

  .hub-pulse {
    left: calc(var(--hub-x) * 1%);
    top: calc(var(--hub-y) * 1%);
    width: 116px;
    height: 116px;
    background: radial-gradient(circle, color-mix(in srgb, var(--accent-2) 26%, transparent), transparent 68%);
    filter: blur(1px);
    animation: hub-pulse 4.8s var(--motion-ease) infinite;
  }

  .subhub-pulse {
    left: calc(var(--subhub-x) * 1%);
    top: calc(var(--subhub-y) * 1%);
    width: 92px;
    height: 92px;
    background: radial-gradient(circle, color-mix(in srgb, var(--accent) 20%, transparent), transparent 70%);
    animation: hub-pulse 5.8s var(--motion-ease) infinite reverse;
  }

  .core-ring {
    position: absolute;
    left: calc(var(--hub-x) * 1%);
    top: calc(var(--hub-y) * 1%);
    width: 176px;
    height: 176px;
    border-radius: 999px;
    z-index: 1;
    border: 1px dashed color-mix(in srgb, var(--accent) 24%, transparent);
    transform: translate(-50%, -50%);
    animation: spin-ring 14s linear infinite;
    pointer-events: none;
  }

  .core-ring::before,
  .core-ring::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 999px;
    border: 1px dashed color-mix(in srgb, var(--accent-2) 28%, transparent);
  }

  .core-ring::before {
    transform: scale(0.72);
    animation: spin-ring 10s linear infinite reverse;
  }

  .core-ring::after {
    transform: scale(1.28);
    animation: spin-ring 18s linear infinite;
  }

  .link-layer {
    position: absolute;
    inset: 0;
    z-index: 1;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .link-layer line {
    fill: none;
    stroke: color-mix(in srgb, var(--accent-2) 18%, var(--accent) 82%);
    stroke-width: 0.18;
    stroke-linecap: round;
    stroke-dasharray: 1.2 1.8;
    stroke-dashoffset: 8;
    opacity: 0;
    transition: opacity 700ms var(--motion-ease);
  }

  .constellation.is-ready .link-layer line {
    opacity: 0.22;
    animation: line-flow 3.4s linear infinite;
    animation-delay: calc(var(--delay) + 1.05s);
  }

  .constellation.is-ready .link-layer line[data-kind='platform'] {
    opacity: 0.38;
    stroke-width: 0.26;
    stroke: color-mix(in srgb, var(--accent-2) 36%, var(--accent) 64%);
  }

  .constellation.is-ready .link-layer line[data-kind='core'] {
    opacity: 0.58;
    stroke-width: 0.4;
    stroke-dasharray: 1.1 1.5;
    stroke: color-mix(in srgb, var(--accent-2) 48%, var(--accent) 52%);
  }

  .node {
    position: absolute;
    left: 50%;
    top: 50%;
    width: var(--size);
    padding: 0;
    border: 0;
    background: transparent;
    display: grid;
    justify-items: center;
    gap: 0.26rem;
    z-index: 2;
    opacity: 0;
    cursor: pointer;
    text-align: center;
    transform: translate(-50%, -50%) scale(0.24);
    transition:
      left 1000ms var(--motion-ease),
      top 1000ms var(--motion-ease),
      opacity 780ms var(--motion-ease),
      transform 1000ms var(--motion-ease);
    transition-delay: var(--delay);
  }

  .constellation.labels-hidden .node {
    gap: 0;
  }

  .node:focus-visible {
    outline: none;
  }

  .node.priority-hero {
    z-index: 3;
  }

  .constellation.is-ready .node {
    left: calc(var(--x) * 1%);
    top: calc(var(--y) * 1%);
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
    animation: node-drift 5200ms var(--motion-ease) infinite;
    animation-delay: calc(var(--delay) + 1.2s);
  }

  .glyph {
    --glyph-scale: 1;
    width: var(--size);
    aspect-ratio: 1;
    border-radius: 16px;
    display: grid;
    place-items: center;
    border: 1px solid color-mix(in srgb, var(--icon-tone-dark) 48%, transparent);
    background:
      radial-gradient(circle at 30% 20%, color-mix(in srgb, var(--icon-tone-dark) 34%, transparent), transparent 45%),
      color-mix(in srgb, var(--card) 84%, transparent);
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--icon-tone-dark) 22%, transparent),
      0 10px 18px rgba(4, 16, 30, 0.22);
    transform-origin: center;
    transition:
      transform 220ms var(--motion-ease),
      box-shadow 220ms var(--motion-ease),
      border-color 220ms var(--motion-ease);
    animation: glyph-breathe 4.2s var(--motion-ease) infinite;
  }

  .node .glyph {
    width: calc(var(--size) * var(--glyph-scale));
    border-radius: calc(16px * var(--glyph-scale));
  }

  :global([data-theme='light']) .glyph {
    border-color: color-mix(in srgb, var(--icon-tone-light) 48%, transparent);
    background:
      radial-gradient(circle at 30% 20%, color-mix(in srgb, var(--icon-tone-light) 18%, rgba(255, 255, 255, 0.58)), transparent 45%),
      linear-gradient(160deg, rgba(255, 255, 255, 0.99), rgba(246, 249, 253, 0.95) 56%, rgba(238, 244, 250, 0.96) 100%);
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--icon-tone-light) 18%, transparent),
      0 14px 24px rgba(15, 28, 46, 0.11),
      inset 0 1px 0 rgba(255, 255, 255, 0.86);
  }

  .node.priority-hero .glyph {
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--icon-tone-dark) 28%, transparent),
      0 14px 28px rgba(4, 16, 30, 0.28);
  }

  :global([data-theme='light']) .node.priority-hero .glyph {
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--icon-tone-light) 22%, transparent),
      0 18px 30px rgba(18, 34, 56, 0.16);
  }

  .node.hub .glyph {
    border-color: color-mix(in srgb, var(--accent-2) 55%, transparent);
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--accent-2) 34%, transparent),
      0 18px 34px rgba(7, 23, 42, 0.3);
  }

  .node.subhub .glyph {
    border-color: color-mix(in srgb, var(--accent) 58%, transparent);
  }

  .node.priority-support .glyph {
    opacity: 0.92;
  }

  .node.is-selected .glyph,
  .node:hover .glyph,
  .node:focus-visible .glyph {
    transform: scale(1.08);
    border-color: color-mix(in srgb, var(--brand) 38%, transparent);
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--brand) 26%, transparent),
      0 18px 34px rgba(4, 16, 30, 0.32);
  }

  :global([data-theme='light']) .node.is-selected .glyph,
  :global([data-theme='light']) .node:hover .glyph,
  :global([data-theme='light']) .node:focus-visible .glyph {
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--brand) 18%, transparent),
      0 20px 34px rgba(15, 28, 46, 0.16),
      inset 0 1px 0 rgba(255, 255, 255, 0.88);
  }

  .glyph svg {
    width: 54%;
    height: 54%;
    fill: var(--icon-tone-dark);
  }

  :global([data-theme='light']) .glyph svg {
    fill: var(--icon-tone-light);
  }

  .glyph img {
    width: 62%;
    height: 62%;
    object-fit: contain;
    border-radius: 4px;
    filter: saturate(1.06) brightness(1.1) contrast(1.12) drop-shadow(0 1px 1px rgba(6, 16, 28, 0.3));
  }

  :global([data-theme='light']) .glyph img {
    filter: saturate(1.02) brightness(0.98) contrast(1.04) drop-shadow(0 1px 1px rgba(18, 34, 56, 0.18));
  }

  .glyph strong {
    font-family: var(--font-mono);
    font-size: 0.84rem;
    color: var(--icon-tone-dark);
  }

  :global([data-theme='light']) .glyph strong {
    color: var(--icon-tone-light);
  }

  .label {
    padding: 0.12rem 0.34rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--brand) 14%, transparent);
    background: color-mix(in srgb, var(--card) 88%, transparent);
    box-shadow: 0 8px 16px rgba(8, 19, 35, 0.08);
    font-size: 0.66rem;
    font-weight: 600;
    color: var(--text-0);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    text-align: center;
    line-height: 1.15;
    max-width: 7.2rem;
    text-wrap: balance;
    opacity: 0.78;
    transform: translate(var(--label-dx), var(--label-dy));
    transition:
      opacity 220ms var(--motion-ease),
      transform 220ms var(--motion-ease),
      background 220ms var(--motion-ease),
      border-color 220ms var(--motion-ease);
  }

  .node.priority-hero .label {
    opacity: 1;
    font-size: 0.62rem;
    font-weight: 700;
    background: color-mix(in srgb, var(--card) 80%, color-mix(in srgb, var(--brand) 12%, transparent));
    border-color: color-mix(in srgb, var(--brand) 22%, transparent);
  }

  .node.priority-core .label {
    opacity: 0.76;
  }

  .node.priority-support .label {
    padding-inline: 0;
    border-color: transparent;
    background: transparent;
    box-shadow: none;
    opacity: 0.34;
    font-size: 0.52rem;
    letter-spacing: 0.04em;
    max-width: 4.6rem;
  }

  .node.compact .label {
    font-size: 0.52rem;
    letter-spacing: 0.04em;
    max-width: 4.5rem;
  }

  .node.compact .glyph img {
    width: 66%;
    height: 66%;
  }

  .node:hover {
    z-index: 5;
  }

  .node:hover .label,
  .node:focus-visible .label {
    opacity: 1;
    transform: translate(var(--label-dx), calc(var(--label-dy) - 1px));
    border-color: color-mix(in srgb, var(--brand) 20%, transparent);
    background: color-mix(in srgb, var(--card) 90%, color-mix(in srgb, var(--brand) 8%, transparent));
  }

  @keyframes node-drift {
    0%,
    100% {
      transform: translate(-50%, -50%) translate(0, 0);
    }
    50% {
      transform: translate(-50%, -50%) translate(calc(var(--dx) * 1px), calc(var(--dy) * 1px));
    }
  }

  @keyframes line-flow {
    0% {
      stroke-dashoffset: 0;
    }
    100% {
      stroke-dashoffset: -7;
    }
  }

  @keyframes glyph-breathe {
    0%,
    100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.04);
    }
  }

