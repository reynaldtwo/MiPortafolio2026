---
import {
  siAstro,
  siCss,
  siDocker,
  siDotnet,
  siFlutter,
  siGit,
  siHtml5,
  siJavascript,
  siN8n,
  siOpenjdk,
  siPostgresql,
  siSqlite,
  siTypescript,
} from 'simple-icons';

interface IconData {
  path: string;
  hex: string;
}

interface TechNode {
  id: string;
  label: string;
  x: number;
  y: number;
  size: number;
  dx: number;
  dy: number;
  icon?: IconData;
  fallback?: string;
}

const nodes: TechNode[] = [
  { id: 'flutter', label: 'Flutter', x: 18, y: 22, size: 52, dx: -6, dy: -4, icon: siFlutter },
  { id: 'astro', label: 'Astro', x: 34, y: 14, size: 46, dx: 7, dy: -6, icon: siAstro },
  { id: 'html', label: 'HTML5', x: 52, y: 12, size: 44, dx: 6, dy: -5, icon: siHtml5 },
  { id: 'css', label: 'CSS', x: 68, y: 18, size: 40, dx: -5, dy: -4, icon: siCss },
  { id: 'js', label: 'JavaScript', x: 80, y: 29, size: 46, dx: 5, dy: 4, icon: siJavascript },
  { id: 'ts', label: 'TypeScript', x: 84, y: 48, size: 42, dx: 6, dy: 4, icon: siTypescript },
  { id: 'dotnet', label: '.NET', x: 74, y: 66, size: 48, dx: -7, dy: 5, icon: siDotnet },
  { id: 'java', label: 'Java', x: 58, y: 80, size: 44, dx: -5, dy: 7, icon: siOpenjdk },
  { id: 'postgres', label: 'PostgreSQL', x: 36, y: 82, size: 44, dx: 5, dy: 6, icon: siPostgresql },
  { id: 'sqlite', label: 'SQLite', x: 18, y: 72, size: 40, dx: -5, dy: 5, icon: siSqlite },
  { id: 'docker', label: 'Docker', x: 10, y: 52, size: 44, dx: -6, dy: -3, icon: siDocker },
  { id: 'git', label: 'Git', x: 9, y: 35, size: 38, dx: -5, dy: 3, icon: siGit },
  { id: 'n8n', label: 'n8n', x: 47, y: 52, size: 50, dx: 0, dy: 0, icon: siN8n },
  { id: 'azure', label: 'Azure', x: 62, y: 40, size: 42, dx: 5, dy: -3, fallback: 'AZ' },
];

const linkPairs: [string, string][] = [
  ['flutter', 'astro'],
  ['flutter', 'n8n'],
  ['astro', 'html'],
  ['html', 'css'],
  ['css', 'js'],
  ['js', 'ts'],
  ['ts', 'dotnet'],
  ['dotnet', 'java'],
  ['dotnet', 'postgres'],
  ['postgres', 'sqlite'],
  ['sqlite', 'docker'],
  ['docker', 'git'],
  ['n8n', 'azure'],
  ['n8n', 'dotnet'],
  ['n8n', 'postgres'],
  ['azure', 'dotnet'],
];

const nodeMap = new Map(nodes.map((node) => [node.id, node]));
const links = linkPairs
  .map(([from, to]) => ({ from: nodeMap.get(from), to: nodeMap.get(to) }))
  .filter((entry): entry is { from: TechNode; to: TechNode } => Boolean(entry.from && entry.to));
---

<div class="constellation" aria-hidden="true" data-constellation>
  <svg class="link-layer" viewBox="0 0 100 100" preserveAspectRatio="none">
    {
      links.map((link, index) => (
        <line x1={link.from.x} y1={link.from.y} x2={link.to.x} y2={link.to.y} style={`--delay:${index * 90}ms`} />
      ))
    }
  </svg>

  <div class="core-ring"></div>

  {
    nodes.map((node, index) => (
      <article
        class="node"
        style={`--x:${node.x};--y:${node.y};--size:${node.size}px;--dx:${node.dx};--dy:${node.dy};--delay:${index * 80}ms;--brand:#${node.icon?.hex ?? '2f7df6'}`}
      >
        <span class="glyph" aria-hidden="true">
          {node.icon ? (
            <svg viewBox="0 0 24 24" role="img" aria-label={node.label}>
              <path d={node.icon.path}></path>
            </svg>
          ) : (
            <strong>{node.fallback}</strong>
          )}
        </span>
        <span class="label">{node.label}</span>
      </article>
    ))
  }
</div>

<script is:inline>
  (() => {
    const roots = document.querySelectorAll('[data-constellation]');
    roots.forEach((root) => {
      window.requestAnimationFrame(() => root.classList.add('is-ready'));
    });
  })();
</script>

<style>
  .constellation {
    position: relative;
    min-height: clamp(300px, 38vw, 390px);
    border-radius: var(--radius-lg);
    border: 1px solid color-mix(in srgb, var(--stroke) 85%, transparent);
    background:
      radial-gradient(circle at 30% 22%, color-mix(in srgb, var(--accent) 20%, transparent), transparent 40%),
      radial-gradient(circle at 78% 74%, color-mix(in srgb, var(--accent-2) 22%, transparent), transparent 45%),
      linear-gradient(145deg, color-mix(in srgb, var(--card) 88%, transparent), color-mix(in srgb, var(--bg-2) 85%, transparent));
    overflow: hidden;
  }

  .core-ring {
    position: absolute;
    inset: 50% auto auto 50%;
    width: 180px;
    height: 180px;
    border-radius: 999px;
    border: 1px dashed color-mix(in srgb, var(--accent) 34%, transparent);
    transform: translate(-50%, -50%);
    animation: spin-ring 14s linear infinite;
    pointer-events: none;
  }

  .core-ring::before,
  .core-ring::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 999px;
    border: 1px dashed color-mix(in srgb, var(--accent-2) 28%, transparent);
  }

  .core-ring::before {
    transform: scale(0.72);
    animation: spin-ring 10s linear infinite reverse;
  }

  .core-ring::after {
    transform: scale(1.28);
    animation: spin-ring 18s linear infinite;
  }

  .link-layer {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .link-layer line {
    fill: none;
    stroke: color-mix(in srgb, var(--accent-2) 30%, var(--accent) 70%);
    stroke-width: 0.32;
    stroke-linecap: round;
    stroke-dasharray: 1.2 1.6;
    stroke-dashoffset: 8;
    opacity: 0;
    transition: opacity 700ms var(--motion-ease);
  }

  .constellation.is-ready .link-layer line {
    opacity: 0.76;
    animation: line-flow 3.4s linear infinite;
    animation-delay: calc(var(--delay) + 1.05s);
  }

  .node {
    position: absolute;
    left: 50%;
    top: 50%;
    width: var(--size);
    display: grid;
    justify-items: center;
    gap: 0.26rem;
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.24);
    transition:
      left 1000ms var(--motion-ease),
      top 1000ms var(--motion-ease),
      opacity 780ms var(--motion-ease),
      transform 1000ms var(--motion-ease);
    transition-delay: var(--delay);
  }

  .constellation.is-ready .node {
    left: calc(var(--x) * 1%);
    top: calc(var(--y) * 1%);
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
    animation: node-drift 5200ms var(--motion-ease) infinite;
    animation-delay: calc(var(--delay) + 1.2s);
  }

  .glyph {
    width: var(--size);
    aspect-ratio: 1;
    border-radius: 16px;
    display: grid;
    place-items: center;
    border: 1px solid color-mix(in srgb, var(--brand) 48%, transparent);
    background:
      radial-gradient(circle at 30% 20%, color-mix(in srgb, var(--brand) 34%, transparent), transparent 45%),
      color-mix(in srgb, var(--card) 84%, transparent);
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--brand) 22%, transparent),
      0 10px 18px rgba(4, 16, 30, 0.22);
    transform-origin: center;
    animation: glyph-breathe 4.2s var(--motion-ease) infinite;
  }

  .glyph svg {
    width: 54%;
    height: 54%;
    fill: color-mix(in srgb, var(--brand) 82%, white 18%);
  }

  .glyph strong {
    font-family: var(--font-mono);
    font-size: 0.84rem;
    color: color-mix(in srgb, var(--brand) 80%, white 20%);
  }

  .label {
    font-size: 0.66rem;
    font-weight: 600;
    color: var(--text-0);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-align: center;
  }

  @keyframes node-drift {
    0%,
    100% {
      transform: translate(-50%, -50%) translate(0, 0);
    }
    50% {
      transform: translate(-50%, -50%) translate(calc(var(--dx) * 1px), calc(var(--dy) * 1px));
    }
  }

  @keyframes line-flow {
    0% {
      stroke-dashoffset: 0;
    }
    100% {
      stroke-dashoffset: -7;
    }
  }

  @keyframes glyph-breathe {
    0%,
    100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.04);
    }
  }

  @keyframes spin-ring {
    to {
      transform: translate(-50%, -50%) rotate(1turn);
    }
  }

  @media (max-width: 560px) {
    .label {
      font-size: 0.6rem;
      letter-spacing: 0.06em;
    }

    .node {
      gap: 0.18rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .core-ring,
    .core-ring::before,
    .core-ring::after,
    .link-layer line,
    .node,
    .glyph {
      animation: none;
      transition: none;
    }

    .node {
      left: calc(var(--x) * 1%);
      top: calc(var(--y) * 1%);
      opacity: 1;
      transform: translate(-50%, -50%) scale(1);
    }

    .link-layer line {
      opacity: 0.6;
      stroke-dashoffset: 0;
    }
  }
</style>
