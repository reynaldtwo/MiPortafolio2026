---
import Button from '../ui/Button.astro';
import LanguageSwitch from './LanguageSwitch.astro';
import ThemeToggle from './ThemeToggle.astro';
import { siteConfig } from '../../data/site';
import type { Locale } from '../../types/content';
import type { I18nDictionary } from '../../data/i18n';

interface Props {
  locale: Locale;
  pathname: string;
  dict: I18nDictionary;
}

const { locale, pathname, dict } = Astro.props;

const navItems = siteConfig.nav.map((item) => ({
  ...item,
  href: `/${locale}/${item.slug}`,
  label: dict.nav[item.key],
}));
---

<header class="header" data-header>
  <div class="container nav-shell">
    <a class="brand" href={`/${locale}`}>
      <span class="brand-mark" aria-hidden="true"><span></span></span>
      <span class="brand-copy">
        <strong>{siteConfig.brandName}</strong>
        <small>Fullstack / Flutter-first</small>
      </span>
    </a>

    <nav class="desktop-nav" aria-label="Primary">
      {
        navItems.map((item) => (
          <a class:list={['nav-link', { active: pathname.startsWith(item.href) }]} href={item.href}>
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="actions">
      <LanguageSwitch locale={locale} pathname={pathname} label={dict.labels.languageSwitch} />
      <ThemeToggle label={dict.labels.themeToggle} />
      <div class="desktop-cta">
        <Button href={siteConfig.contact.email} variant="secondary">
          {dict.ctas.email}
        </Button>
        <Button href={siteConfig.contact.booking} target="_blank">
          {dict.ctas.schedule}
        </Button>
      </div>
      <button
        class="menu-btn"
        type="button"
        aria-expanded="false"
        aria-controls="mobile-nav"
        data-menu-toggle
        aria-label={dict.labels.mobileMenu}
      >
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <div id="mobile-nav" class="mobile-nav" data-mobile-nav hidden>
    <div class="mobile-nav-inner surface">
      <div class="mobile-head">
        <div>
          <strong>{siteConfig.brandName}</strong>
          <small>Menu</small>
        </div>
        <button type="button" data-menu-close aria-label={dict.labels.closeMenu}>x</button>
      </div>
      <nav class="mobile-links" aria-label="Mobile primary">
        {
          navItems.map((item) => (
            <a class:list={['mobile-link', { active: pathname.startsWith(item.href) }]} href={item.href}>
              {item.label}
            </a>
          ))
        }
      </nav>
      <div class="mobile-cta stack-4">
        <Button href={siteConfig.contact.booking} target="_blank" fullWidth={true}>
          {dict.ctas.schedule}
        </Button>
        <Button href={siteConfig.contact.email} variant="secondary" fullWidth={true}>
          {dict.ctas.email}
        </Button>
      </div>
    </div>
  </div>
</header>

<script>
  const header = document.currentScript?.closest('[data-header]');
  if (header) {
    const toggle = header.querySelector('[data-menu-toggle]');
    const closeBtn = header.querySelector('[data-menu-close]');
    const panel = header.querySelector('[data-mobile-nav]');
    const panelInner = header.querySelector('.mobile-nav-inner');
    const links = header.querySelectorAll('.mobile-link');

    const closeMenu = () => {
      if (!panel || !toggle) return;
      panel.classList.remove('is-open');
      window.setTimeout(() => panel.setAttribute('hidden', ''), 220);
      toggle.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    };

    const openMenu = () => {
      if (!panel || !toggle) return;
      panel.removeAttribute('hidden');
      window.requestAnimationFrame(() => panel.classList.add('is-open'));
      toggle.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    };

    toggle?.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      if (expanded) closeMenu();
      else openMenu();
    });

    closeBtn?.addEventListener('click', closeMenu);
    links.forEach((link) => link.addEventListener('click', closeMenu));

    panel?.addEventListener('click', (event) => {
      if (!panelInner) return;
      if (event.target === panel) closeMenu();
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') closeMenu();
    });
  }
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 80;
    backdrop-filter: blur(14px);
    background: color-mix(in srgb, var(--bg-0) 78%, transparent);
    border-bottom: 1px solid color-mix(in srgb, var(--stroke) 86%, transparent);
  }

  .nav-shell {
    min-height: 4.6rem;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--space-4);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    min-width: max-content;
  }

  .brand-mark {
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 0.55rem;
    background: linear-gradient(145deg, var(--accent), var(--accent-2));
    display: grid;
    place-items: center;
    box-shadow: 0 10px 20px rgba(11, 53, 123, 0.35);
  }

  .brand-mark span {
    width: 0.72rem;
    height: 0.72rem;
    border-radius: 0.2rem;
    border: 2px solid rgba(255, 255, 255, 0.86);
  }

  .brand-copy {
    display: grid;
    line-height: 1.08;
  }

  .brand-copy strong {
    font-family: var(--font-heading);
    font-size: 0.96rem;
    letter-spacing: 0.01em;
    color: var(--text-0);
  }

  .brand-copy small {
    font-family: var(--font-mono);
    font-size: 0.67rem;
    color: var(--muted);
  }

  .desktop-nav {
    justify-self: center;
    display: flex;
    align-items: center;
    gap: clamp(0.7rem, 1.7vw, 1.3rem);
    padding: 0.4rem;
    border-radius: 999px;
    border: 1px solid var(--stroke);
    background: color-mix(in srgb, var(--card) 85%, transparent);
  }

  .nav-link {
    position: relative;
    color: var(--text-1);
    font-size: 0.93rem;
    font-weight: 500;
    padding: 0.36rem 0.72rem;
    border-radius: 999px;
    transition:
      color var(--motion-fast) var(--motion-ease),
      background-color var(--motion-fast) var(--motion-ease);
  }

  .nav-link.active,
  .nav-link:hover {
    color: var(--text-0);
    background: color-mix(in srgb, var(--accent) 18%, transparent);
  }

  .actions {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }

  .desktop-cta {
    display: inline-flex;
    gap: 0.45rem;
  }

  .menu-btn {
    display: none;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 999px;
    border: 1px solid var(--stroke);
    background: color-mix(in srgb, var(--card) 85%, transparent);
    padding: 0;
    place-items: center;
  }

  .menu-btn span {
    display: block;
    width: 1rem;
    height: 1.5px;
    margin: 2px auto;
    background: var(--text-0);
  }

  .mobile-nav {
    position: fixed;
    inset: 0;
    background: color-mix(in srgb, var(--bg-0) 78%, transparent);
    backdrop-filter: blur(12px);
    padding: 1.15rem;
    opacity: 0;
    transition: opacity var(--motion-base) var(--motion-ease);
  }

  .mobile-nav.is-open {
    opacity: 1;
  }

  .mobile-nav-inner {
    max-width: 420px;
    margin-left: auto;
    padding: var(--space-5);
    transform: translateX(16px);
    opacity: 0;
    transition:
      transform var(--motion-base) var(--motion-ease),
      opacity var(--motion-base) var(--motion-ease);
  }

  .mobile-nav.is-open .mobile-nav-inner {
    transform: translateX(0);
    opacity: 1;
  }

  .mobile-head {
    display: flex;
    align-items: start;
    justify-content: space-between;
    margin-bottom: var(--space-5);
  }

  .mobile-head strong {
    display: block;
    font-family: var(--font-heading);
    color: var(--text-0);
  }

  .mobile-head small {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--muted);
  }

  .mobile-head button {
    border: 0;
    background: transparent;
    color: var(--text-0);
    font-size: 1.1rem;
    text-transform: uppercase;
  }

  .mobile-links {
    display: grid;
    gap: var(--space-3);
    margin-bottom: var(--space-5);
  }

  .mobile-link {
    color: var(--text-1);
    font-size: 1rem;
    padding: 0.45rem 0.6rem;
    border-radius: 0.7rem;
    border: 1px solid transparent;
    transition:
      color var(--motion-fast) var(--motion-ease),
      border-color var(--motion-fast) var(--motion-ease),
      background-color var(--motion-fast) var(--motion-ease);
  }

  .mobile-link.active,
  .mobile-link:hover {
    color: var(--text-0);
    border-color: var(--stroke);
    background: color-mix(in srgb, var(--card) 90%, transparent);
  }

  @media (max-width: 1080px) {
    .desktop-nav,
    .desktop-cta {
      display: none;
    }

    .nav-shell {
      grid-template-columns: 1fr auto;
      min-height: 4.2rem;
    }

    .menu-btn {
      display: grid;
    }
  }

  @media (max-width: 560px) {
    .brand-copy small {
      display: none;
    }
  }
</style>
