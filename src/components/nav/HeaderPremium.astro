---
import Button from '../ui/Button.astro';
import BrandStackMark from './BrandStackMark.astro';
import LanguageSwitch from './LanguageSwitch.astro';
import ThemeToggle from './ThemeToggle.astro';
import { siteConfig } from '../../data/site';
import type { Locale } from '../../types/content';
import type { I18nDictionary } from '../../data/i18n';
import pdfIcon from '../../../Recursos/pdf.png';
import gmailIcon from '../../../Recursos/gmail.png';

interface Props {
  locale: Locale;
  pathname: string;
  dict: I18nDictionary;
}

const { locale, pathname, dict } = Astro.props;

const normalizePath = (value: string) => {
  if (value === '/') return '/';
  return value.replace(/\/+$/, '');
};

const localeRoot = `/${locale}`;
const normalizedPathname = normalizePath(pathname);
const navItems = siteConfig.nav.map((item) => ({
  ...item,
  href: item.slug ? `/${locale}/${item.slug}` : localeRoot,
  label: dict.nav[item.key],
  active: item.slug ? normalizedPathname.startsWith(`/${locale}/${item.slug}`) : normalizedPathname === localeRoot,
}));

const calendlyIconPath =
  'M19.655 14.262c.281 0 .557.023.828.064 0 .005-.005.01-.005.014-.105.267-.234.534-.381.786l-1.219 2.106c-1.112 1.936-3.177 3.127-5.411 3.127h-2.432c-2.23 0-4.294-1.191-5.412-3.127l-1.218-2.106a6.251 6.251 0 0 1 0-6.252l1.218-2.106C6.736 4.832 8.8 3.641 11.035 3.641h2.432c2.23 0 4.294 1.191 5.411 3.127l1.219 2.106c.147.252.271.519.381.786 0 .004.005.009.005.014-.267.041-.543.064-.828.064-1.816 0-2.501-.607-3.291-1.306-.764-.676-1.711-1.517-3.44-1.517h-1.029c-1.251 0-2.387.455-3.2 1.278-.796.805-1.233 1.904-1.233 3.099v1.411c0 1.196.437 2.295 1.233 3.099.813.823 1.949 1.278 3.2 1.278h1.034c1.729 0 2.676-.841 3.439-1.517.791-.703 1.471-1.306 3.287-1.301Zm.005-3.237c.399 0 .794-.036 1.179-.11-.002-.004-.002-.01-.002-.014-.073-.414-.193-.823-.349-1.218.731-.12 1.407-.396 1.986-.819 0-.004-.005-.013-.005-.018-.331-1.085-.832-2.101-1.489-3.03-.649-.915-1.435-1.719-2.331-2.395-1.867-1.398-4.088-2.138-6.428-2.138-1.448 0-2.855.28-4.175.841-1.273.543-2.423 1.315-3.407 2.299S2.878 6.552 2.341 7.83c-.557 1.324-.842 2.726-.842 4.175 0 1.448.281 2.855.842 4.174.542 1.274 1.314 2.423 2.298 3.407s2.129 1.761 3.407 2.299c1.324.556 2.727.841 4.175.841 2.34 0 4.561-.74 6.428-2.137a10.815 10.815 0 0 0 2.331-2.396c.652-.929 1.158-1.949 1.489-3.03 0-.004.005-.014.005-.018-.579-.423-1.255-.699-1.986-.819.161-.395.276-.804.349-1.218.005-.009.005-.014.005-.023.869.166 1.692.506 2.404 1.035.685.505.552 1.075.446 1.416C22.184 20.437 17.619 24 12.221 24c-6.625 0-12-5.375-12-12s5.37-12 12-12c5.398 0 9.963 3.563 11.471 8.464.106.341.239.915-.446 1.421-.717.529-1.535.873-2.404 1.034.128.716.128 1.45 0 2.166-.387-.074-.782-.11-1.182-.11-4.184 0-3.968 2.823-6.736 2.823h-1.029c-1.899 0-3.15-1.357-3.15-3.095v-1.411c0-1.738 1.251-3.094 3.15-3.094h1.034c2.768 0 2.552 2.823 6.731 2.827Z';
---

<header class="header" data-header>
  <div class="container nav-shell">
    <a class="brand" href={`/${locale}`}>
      <BrandStackMark />
      <span class="brand-copy">
        <strong>{siteConfig.brandName}</strong>
        <small>Fullstack / Flutter-first</small>
      </span>
    </a>

    <div class="desktop-cluster">
      <nav class="desktop-nav" aria-label="Primary">
        {
          navItems.map((item) => (
            <a class:list={['nav-link', { active: item.active }]} href={item.href}>
              {item.label}
            </a>
          ))
        }
      </nav>

      <div class="actions">
        <LanguageSwitch locale={locale} pathname={pathname} label={dict.labels.languageSwitch} />
        <ThemeToggle label={dict.labels.themeToggle} />
        <div class="desktop-cta">
          <Button
            variant="secondary"
            className="header-cta header-cta--pdf header-cta--icon"
            disabled={true}
            ariaLabel={dict.labels.resumePdfSoon}
            title={dict.labels.resumePdfSoon}
          >
            <span class="header-cta__icon" aria-hidden="true">
              <img src={pdfIcon.src} alt="" loading="lazy" decoding="async" />
            </span>
          </Button>
          <Button
            href={siteConfig.contact.email}
            variant="secondary"
            className="header-cta header-cta--mail header-cta--icon"
            ariaLabel={dict.ctas.email}
            title={dict.ctas.email}
          >
            <span class="header-cta__icon" aria-hidden="true">
              <img src={gmailIcon.src} alt="" loading="lazy" decoding="async" />
            </span>
          </Button>
          <Button href={siteConfig.contact.booking} target="_blank" variant="secondary" className="header-cta header-cta--book">
            <span class="header-cta__content">
              <span class="header-cta__icon header-cta__icon--svg" aria-hidden="true">
                <svg viewBox="0 0 24 24" focusable="false">
                  <path d={calendlyIconPath}></path>
                </svg>
              </span>
              <span class="header-cta__label">{dict.ctas.schedule}</span>
            </span>
          </Button>
        </div>
        <button
          class="menu-btn"
          type="button"
          aria-expanded="false"
          aria-controls="mobile-nav"
          data-menu-toggle
          aria-label={dict.labels.mobileMenu}
        >
          <span class="menu-btn__inner" aria-hidden="true">
            <span class="menu-btn__panel"></span>
            <span class="menu-btn__rail"></span>
            <span class="menu-btn__line menu-btn__line--top"></span>
            <span class="menu-btn__line menu-btn__line--bottom"></span>
            <span class="menu-btn__dot"></span>
          </span>
        </button>
      </div>
    </div>
  </div>

  <div id="mobile-nav" class="mobile-nav" data-mobile-nav hidden>
    <div class="mobile-nav-inner surface">
      <div class="mobile-head">
        <div class="mobile-brand-block">
          <strong>{siteConfig.brandName}</strong>
        </div>
        <button class="mobile-close" type="button" data-menu-close aria-label={dict.labels.closeMenu}>
          <span></span><span></span>
        </button>
      </div>
      <nav class="mobile-links" aria-label="Mobile primary">
        {
          navItems.map((item, index) => (
            <a class:list={['mobile-link', { active: item.active }]} href={item.href}>
              <span class="mobile-link__index">{String(index + 1).padStart(2, '0')}</span>
              <span class="mobile-link__label">{item.label}</span>
              <span class="mobile-link__arrow" aria-hidden="true">
                <svg viewBox="0 0 24 24" focusable="false">
                  <path d="M8 12h8"></path>
                  <path d="M12 8l4 4-4 4"></path>
                </svg>
              </span>
            </a>
          ))
        }
      </nav>
      <div class="mobile-cta stack-4">
        <Button
          variant="secondary"
          fullWidth={true}
          className="header-cta header-cta--pdf"
          disabled={true}
          ariaLabel={dict.labels.resumePdfSoon}
          title={dict.labels.resumePdfSoon}
        >
          <span class="header-cta__content">
            <span class="header-cta__icon" aria-hidden="true">
              <img src={pdfIcon.src} alt="" loading="lazy" decoding="async" />
            </span>
            <span class="header-cta__label">CV</span>
          </span>
        </Button>
        <Button href={siteConfig.contact.booking} target="_blank" fullWidth={true} variant="secondary" className="header-cta header-cta--book">
          <span class="header-cta__content">
            <span class="header-cta__icon header-cta__icon--svg" aria-hidden="true">
              <svg viewBox="0 0 24 24" focusable="false">
                <path d={calendlyIconPath}></path>
              </svg>
            </span>
            <span class="header-cta__label">{dict.ctas.schedule}</span>
          </span>
        </Button>
        <Button href={siteConfig.contact.email} variant="secondary" fullWidth={true} className="header-cta header-cta--mail">
          <span class="header-cta__content">
            <span class="header-cta__icon" aria-hidden="true">
              <img src={gmailIcon.src} alt="" loading="lazy" decoding="async" />
            </span>
            <span class="header-cta__label">{dict.ctas.email}</span>
          </span>
        </Button>
      </div>
    </div>
  </div>
</header>

<script>
  document.querySelectorAll('[data-header]').forEach((header) => {
    const toggle = header.querySelector('[data-menu-toggle]');
    const closeBtn = header.querySelector('[data-menu-close]');
    const panel = header.querySelector('[data-mobile-nav]');
    const panelInner = header.querySelector('.mobile-nav-inner');
    const links = header.querySelectorAll('.mobile-link');

    const closeMenu = () => {
      if (!panel || !toggle) return;
      panel.classList.remove('is-open');
      window.setTimeout(() => panel.setAttribute('hidden', ''), 220);
      toggle.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    };

    const openMenu = () => {
      if (!panel || !toggle) return;
      panel.removeAttribute('hidden');
      window.requestAnimationFrame(() => panel.classList.add('is-open'));
      toggle.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    };

    toggle?.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      if (expanded) closeMenu();
      else openMenu();
    });

    closeBtn?.addEventListener('click', closeMenu);
    links.forEach((link) => link.addEventListener('click', closeMenu));

    panel?.addEventListener('click', (event) => {
      if (!panelInner) return;
      if (event.target === panel) closeMenu();
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') closeMenu();
    });
  });
</script>

<style>
  .header {
    --header-control-height: 2.2rem;
  }

  .header {
    position: sticky;
    top: 0;
    z-index: 80;
    backdrop-filter: blur(14px);
    background: color-mix(in srgb, var(--bg-0) 78%, transparent);
    border-bottom: 1px solid color-mix(in srgb, var(--stroke) 86%, transparent);
  }

  :global([data-theme='light']) .header {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(243, 248, 253, 0.84)),
      color-mix(in srgb, var(--bg-1) 84%, transparent);
    border-bottom-color: color-mix(in srgb, var(--stroke) 96%, rgba(255, 255, 255, 0.82));
    box-shadow:
      0 20px 40px rgba(15, 28, 46, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.76),
      inset 0 -1px 0 rgba(16, 29, 47, 0.04);
  }

  .nav-shell {
    min-height: 4.6rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: clamp(0.75rem, 1.2vw, 1.1rem);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--cluster-gap);
    min-width: max-content;
  }

  .brand-copy {
    display: grid;
    line-height: 1.08;
    gap: 0.12rem;
  }

  .brand-copy strong {
    font-family: var(--font-heading);
    font-size: 0.96rem;
    letter-spacing: 0.01em;
    color: var(--text-0);
  }

  .brand-copy small {
    font-family: var(--font-mono);
    font-size: 0.67rem;
    color: var(--muted);
  }

  .desktop-cluster {
    display: inline-flex;
    align-items: center;
    justify-content: flex-end;
    gap: clamp(0.75rem, 1.35vw, 1.15rem);
    min-width: 0;
    margin-left: auto;
  }

  .desktop-nav {
    display: flex;
    align-items: center;
    gap: clamp(0.45rem, 1vw, 0.95rem);
    padding: 0.35rem;
    border-radius: 999px;
    border: 1px solid var(--stroke);
    background: color-mix(in srgb, var(--card) 92%, transparent);
  }

  :global([data-theme='light']) .desktop-nav {
    background:
      radial-gradient(circle at 14% 18%, rgba(255, 255, 255, 0.84), transparent 28%),
      linear-gradient(160deg, rgba(255, 255, 255, 0.99), rgba(246, 249, 253, 0.94) 60%, rgba(238, 244, 250, 0.95) 100%);
    border-color: color-mix(in srgb, var(--stroke) 96%, rgba(255, 255, 255, 0.84));
    box-shadow:
      0 12px 24px rgba(15, 28, 46, 0.06),
      inset 0 1px 0 rgba(255, 255, 255, 0.88),
      inset 0 -1px 0 rgba(16, 29, 47, 0.04);
  }

  .nav-link {
    position: relative;
    color: var(--card-text-1);
    font-size: 0.93rem;
    font-weight: 500;
    white-space: nowrap;
    padding: 0.36rem clamp(0.56rem, 0.78vw, 0.78rem);
    border-radius: 999px;
    transition:
      color var(--motion-fast) var(--motion-ease),
      background var(--motion-fast) var(--motion-ease),
      box-shadow var(--motion-fast) var(--motion-ease);
  }

  .nav-link.active,
  .nav-link:hover,
  .nav-link:focus-visible {
    color: var(--text-0);
    background: color-mix(in srgb, var(--accent) 20%, color-mix(in srgb, var(--card) 88%, transparent));
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--accent) 24%, transparent);
  }

  :global([data-theme='light']) .nav-link:hover,
  :global([data-theme='light']) .nav-link:focus-visible {
    color: var(--text-0);
    background:
      linear-gradient(160deg, rgba(255, 255, 255, 0.99), rgba(244, 248, 253, 0.92) 64%, rgba(237, 243, 249, 0.92) 100%);
    box-shadow:
      inset 0 0 0 1px color-mix(in srgb, var(--stroke-strong) 70%, rgba(255, 255, 255, 0.18)),
      0 8px 16px rgba(15, 28, 46, 0.05);
  }

  :global([data-theme='light']) .nav-link.active,
  :global([data-theme='light']) .nav-link.active:hover,
  :global([data-theme='light']) .nav-link.active:focus-visible {
    color: #fbf8f2;
    background: linear-gradient(140deg, #0d1d4a 0%, #1748b6 56%, #0c8a92 148%);
    box-shadow:
      0 12px 22px rgba(13, 29, 74, 0.18),
      inset 0 1px 0 rgba(255, 255, 255, 0.12);
  }

  .actions {
    display: inline-flex;
    align-items: center;
    min-width: max-content;
    gap: var(--cluster-gap);
  }

  .desktop-cta {
    display: inline-flex;
    gap: var(--inline-gap-md);
  }

  .desktop-cta :global(.btn) {
    white-space: nowrap;
    flex: 0 0 auto;
    height: var(--header-control-height);
    padding-block: 0;
    padding-inline: clamp(0.92rem, 1vw, 1.08rem);
    font-size: 0.89rem;
    font-weight: 600;
  }

  .desktop-cta :global(.btn-primary) {
    box-shadow: 0 10px 20px rgba(16, 74, 168, 0.34);
  }

  .desktop-cta :global(.btn-primary:hover) {
    box-shadow: 0 12px 22px rgba(14, 65, 148, 0.38);
  }

  .desktop-cta :global(.header-cta) {
    border-color: color-mix(in srgb, var(--stroke) 92%, transparent);
    background: color-mix(in srgb, var(--card) 90%, transparent);
  }

  :global([data-theme='light']) .desktop-cta :global(.header-cta) {
    background:
      radial-gradient(circle at 18% 18%, rgba(255, 255, 255, 0.8), transparent 28%),
      linear-gradient(160deg, rgba(255, 255, 255, 0.99), rgba(246, 249, 253, 0.94) 58%, rgba(238, 244, 250, 0.95) 100%);
    box-shadow:
      0 10px 18px rgba(15, 28, 46, 0.06),
      inset 0 1px 0 rgba(255, 255, 255, 0.86);
  }

  :global([data-theme='light']) .desktop-cta :global(.header-cta:hover),
  :global([data-theme='light']) .desktop-cta :global(.header-cta:focus-visible) {
    background:
      radial-gradient(circle at 18% 18%, rgba(255, 255, 255, 0.88), transparent 30%),
      linear-gradient(160deg, rgba(255, 255, 255, 1), rgba(247, 250, 254, 0.96) 58%, rgba(240, 246, 251, 0.97) 100%);
    box-shadow:
      0 14px 22px rgba(15, 28, 46, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.9);
  }

  .desktop-cta :global(.header-cta:hover),
  .desktop-cta :global(.header-cta:focus-visible) {
    border-color: var(--stroke-strong);
    background: color-mix(
      in srgb,
      var(--card) 96%,
      color-mix(in srgb, var(--header-cta-accent, var(--accent)) 10%, transparent)
    );
  }

  .desktop-cta :global(.header-cta--pdf) {
    --header-cta-accent: #e65b65;
  }

  .desktop-cta :global(.header-cta--mail) {
    --header-cta-accent: #ff7f63;
  }

  .desktop-cta :global(.header-cta--book) {
    --header-cta-accent: #006bff;
  }

  .desktop-cta :global(.header-cta--icon) {
    width: 3.62rem;
    min-width: 3.62rem;
    padding-inline: 0;
    justify-content: center;
  }

  .header-cta__content {
    display: inline-flex;
    align-items: center;
    gap: var(--inline-gap);
  }

  .header-cta__icon {
    display: inline-grid;
    place-items: center;
    width: 1.08rem;
    height: 1.08rem;
  }

  .desktop-cta :global(.header-cta--icon .header-cta__icon) {
    width: 1.3rem;
    height: 1.3rem;
  }

  .header-cta__icon img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
  }

  .header-cta__icon--svg {
    color: var(--header-cta-accent, #006bff);
  }

  .header-cta__icon svg {
    width: 100%;
    height: 100%;
    display: block;
    fill: currentColor;
  }

  .header-cta__label {
    color: var(--text-0);
    letter-spacing: 0.01em;
  }

  .desktop-cta :global(.header-cta.is-disabled),
  .desktop-cta :global(.header-cta:disabled) {
    opacity: 0.92;
  }

  .desktop-cta :global(.header-cta.is-disabled .header-cta__icon),
  .desktop-cta :global(.header-cta:disabled .header-cta__icon) {
    opacity: 0.92;
  }

  .menu-btn {
    display: none;
    width: 2.7rem;
    height: 2.7rem;
    border-radius: 1rem;
    border: 1px solid var(--stroke);
    background: color-mix(in srgb, var(--card) 85%, transparent);
    padding: 0;
    place-items: center;
    position: relative;
    overflow: hidden;
    box-shadow:
      0 10px 18px rgba(8, 19, 35, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
    transition:
      border-color var(--motion-fast) var(--motion-ease),
      background var(--motion-fast) var(--motion-ease),
      transform var(--motion-fast) var(--motion-ease),
      box-shadow var(--motion-fast) var(--motion-ease),
      opacity var(--motion-fast) var(--motion-ease);
  }

  .menu-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 22% 20%, color-mix(in srgb, var(--accent) 14%, transparent), transparent 36%),
      linear-gradient(160deg, color-mix(in srgb, var(--card) 95%, transparent), color-mix(in srgb, var(--bg-2) 56%, transparent));
    opacity: 0.96;
    pointer-events: none;
  }

  .menu-btn__inner {
    position: relative;
    width: 1.18rem;
    height: 0.96rem;
    z-index: 1;
  }

  .menu-btn__panel {
    position: absolute;
    inset: 0;
    border-radius: 0.42rem;
    border: 1px solid color-mix(in srgb, var(--stroke-strong) 26%, transparent);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.1), transparent);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08);
    transition:
      border-color var(--motion-fast) var(--motion-ease),
      background var(--motion-fast) var(--motion-ease),
      box-shadow var(--motion-fast) var(--motion-ease);
  }

  .menu-btn__rail {
    position: absolute;
    left: 0.08rem;
    top: 0.08rem;
    bottom: 0.08rem;
    width: 0.16rem;
    border-radius: 999px;
    background: linear-gradient(180deg, var(--accent), var(--accent-2));
    box-shadow: 0 0 12px color-mix(in srgb, var(--accent) 28%, transparent);
    transition:
      transform var(--motion-base) var(--motion-ease),
      box-shadow var(--motion-base) var(--motion-ease);
  }

  .menu-btn__line {
    position: absolute;
    left: 0.38rem;
    height: 1.8px;
    border-radius: 999px;
    background: var(--text-0);
    transition:
      transform var(--motion-base) var(--motion-ease),
      width var(--motion-base) var(--motion-ease),
      background var(--motion-fast) var(--motion-ease),
      opacity var(--motion-fast) var(--motion-ease);
  }

  .menu-btn__line--top {
    top: 0.22rem;
    width: 0.58rem;
  }

  .menu-btn__line--bottom {
    top: 0.48rem;
    width: 0.44rem;
  }

  .menu-btn__dot {
    position: absolute;
    left: 0.38rem;
    bottom: 0.16rem;
    width: 0.18rem;
    height: 0.18rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent) 78%, white 22%);
    box-shadow:
      0 0 0 3px color-mix(in srgb, var(--accent) 14%, transparent),
      0 0 10px color-mix(in srgb, var(--accent) 22%, transparent);
    transition:
      transform var(--motion-base) var(--motion-ease),
      box-shadow var(--motion-base) var(--motion-ease),
      background var(--motion-fast) var(--motion-ease);
  }

  :global([data-theme='light']) .menu-btn {
    background:
      radial-gradient(circle at 18% 18%, rgba(255, 255, 255, 0.82), transparent 28%),
      linear-gradient(160deg, rgba(255, 255, 255, 0.99), rgba(246, 249, 253, 0.94) 60%, rgba(238, 244, 250, 0.95) 100%);
    box-shadow:
      0 12px 20px rgba(15, 28, 46, 0.06),
      inset 0 1px 0 rgba(255, 255, 255, 0.88);
  }

  .menu-btn:hover,
  .menu-btn:focus-visible {
    transform: translateY(-1px);
    border-color: var(--stroke-strong);
    background: color-mix(in srgb, var(--card) 96%, color-mix(in srgb, var(--accent) 8%, transparent));
    box-shadow:
      0 14px 22px rgba(8, 19, 35, 0.12),
