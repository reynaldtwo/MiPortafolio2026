---
import sunIcon from '../../../Recursos/Sol.png';

interface Props {
  label: string;
}

const { label } = Astro.props;
---

<button class="theme-toggle" type="button" data-theme-toggle aria-label={label} title={label} aria-pressed="false">
  <span class="slot sun" aria-hidden="true">
    <span class="icon-image sun-image" style={`background-image:url(${sunIcon.src})`}></span>
  </span>
  <span class="slot moon" aria-hidden="true">
    <svg viewBox="0 0 24 24" class="icon icon-moon" focusable="false">
      <path d="M19.35 14.27A7.95 7.95 0 0 1 9.73 4.65 8.2 8.2 0 1 0 19.35 14.27Z"></path>
      <path d="M16.75 4.25v2.1"></path>
      <path d="M15.7 5.3h2.1"></path>
    </svg>
  </span>
  <span class="knob" aria-hidden="true">
    <span class="knob-image knob-sun-image" style={`background-image:url(${sunIcon.src})`}></span>
    <svg viewBox="0 0 24 24" class="knob-icon knob-icon-moon" focusable="false">
      <path d="M19.35 14.27A7.95 7.95 0 0 1 9.73 4.65 8.2 8.2 0 1 0 19.35 14.27Z"></path>
    </svg>
  </span>
</button>

<style>
  .theme-toggle {
    width: 3.75rem;
    height: 2.2rem;
    padding: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    border: 1px solid var(--stroke);
    background:
      radial-gradient(circle at 26% 50%, rgba(247, 182, 74, 0.14), transparent 28%),
      radial-gradient(circle at 74% 50%, rgba(196, 216, 224, 0.16), transparent 32%),
      linear-gradient(
        90deg,
        color-mix(in srgb, var(--accent-warm) 5%, var(--card) 95%),
        color-mix(in srgb, #9dbef7 10%, var(--card) 90%)
      );
    color: var(--text-0);
    position: relative;
    overflow: hidden;
    box-shadow:
      inset 0 0 0 1px color-mix(in srgb, var(--stroke) 68%, transparent),
      0 8px 18px rgba(8, 19, 35, 0.08);
    transition:
      transform var(--motion-fast) var(--motion-ease),
      border-color var(--motion-fast) var(--motion-ease),
      background var(--motion-fast) var(--motion-ease),
      box-shadow var(--motion-fast) var(--motion-ease);
  }

  .theme-toggle:hover {
    transform: translateY(-1px);
    border-color: var(--stroke-strong);
    box-shadow:
      inset 0 0 0 1px color-mix(in srgb, var(--stroke-strong) 74%, transparent),
      0 12px 20px rgba(8, 19, 35, 0.12);
  }

  .theme-toggle:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--accent) 70%, white 30%);
    outline-offset: 3px;
  }

  .theme-toggle .slot {
    position: absolute;
    top: 50%;
    width: 1rem;
    height: 1rem;
    display: grid;
    place-items: center;
    transition:
      opacity var(--motion-base) var(--motion-ease),
      transform var(--motion-base) var(--motion-ease),
      filter var(--motion-base) var(--motion-ease);
  }

  .theme-toggle .sun {
    left: 0.4rem;
    transform: translateY(-50%);
  }

  .theme-toggle .moon {
    right: 0.38rem;
    transform: translateY(-50%);
  }

  .theme-toggle .icon {
    width: 1rem;
    height: 1rem;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.85;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .theme-toggle .icon-image {
    width: 0.94rem;
    height: 0.94rem;
    display: block;
    background-position: center;
    background-repeat: no-repeat;
    background-size: contain;
  }

  .theme-toggle .sun-image {
    filter: drop-shadow(0 0 8px rgba(237, 180, 44, 0.24));
  }

  .theme-toggle .icon-moon {
    color: #d7e5fb;
    filter: drop-shadow(0 0 8px rgba(215, 229, 251, 0.22));
  }

  .theme-toggle .knob {
    position: absolute;
    top: 50%;
    left: 0.24rem;
    width: 1.5rem;
    height: 1.5rem;
    display: grid;
    place-items: center;
    isolation: isolate;
    border-radius: 999px;
    background: linear-gradient(145deg, #ffffff, #edf2f8);
    border: 1px solid var(--stroke-strong);
    box-shadow:
      0 8px 16px rgba(7, 23, 42, 0.16),
      inset 0 1px 0 rgba(255, 255, 255, 0.42);
    transform: translateY(-50%);
    transition:
      transform var(--motion-base) var(--motion-ease),
      background var(--motion-base) var(--motion-ease),
      border-color var(--motion-base) var(--motion-ease),
      box-shadow var(--motion-base) var(--motion-ease);
  }

  .theme-toggle .knob::before {
    content: '';
    position: absolute;
    inset: 0.2rem;
    z-index: 0;
    border-radius: 999px;
    background: radial-gradient(circle at 35% 35%, rgba(255, 255, 255, 0.7), rgba(255, 255, 255, 0.14));
    transition: background var(--motion-base) var(--motion-ease);
  }

  .theme-toggle .knob-image,
  .theme-toggle .knob-icon {
    position: absolute;
    z-index: 1;
    transition:
      opacity var(--motion-base) var(--motion-ease),
      transform var(--motion-base) var(--motion-ease),
      filter var(--motion-base) var(--motion-ease),
      color var(--motion-base) var(--motion-ease);
  }

  .theme-toggle .knob-image {
    width: 1.14rem;
    height: 1.14rem;
    display: block;
    background-position: center;
    background-repeat: no-repeat;
    background-size: contain;
  }

  .theme-toggle .knob-sun-image {
    filter: drop-shadow(0 0 10px rgba(237, 180, 44, 0.2));
  }

  .theme-toggle .knob-icon {
    width: 1.02rem;
    height: 1.02rem;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.85;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .theme-toggle .knob-icon-moon {
    color: #dce8ff;
  }

  [data-theme='dark'] .theme-toggle .sun {
    opacity: 0.34;
    transform: translateY(-50%) scale(0.92);
    filter: saturate(0.92);
  }

  [data-theme='dark'] .theme-toggle .moon {
    opacity: 1;
    transform: translateY(-50%) scale(1);
    filter: saturate(1.04);
  }

  [data-theme='dark'] .theme-toggle .icon-moon {
    color: #d7e5fb;
    filter: drop-shadow(0 0 8px rgba(215, 229, 251, 0.22));
  }

  [data-theme='dark'] .theme-toggle {
    background:
      radial-gradient(circle at 26% 50%, rgba(247, 182, 74, 0.08), transparent 26%),
      radial-gradient(circle at 74% 50%, rgba(196, 216, 224, 0.24), transparent 34%),
      linear-gradient(90deg, color-mix(in srgb, #16253c 82%, transparent), color-mix(in srgb, #0f1b2a 60%, #1d3553 40%));
  }

  [data-theme='dark'] .theme-toggle .knob {
    transform: translate(1.98rem, -50%);
    background: linear-gradient(145deg, #dbe8ff, #9eb8db);
    border-color: color-mix(in srgb, #dbe8ff 42%, var(--stroke-strong));
    box-shadow:
      0 8px 16px rgba(7, 23, 42, 0.22),
      inset 0 1px 0 rgba(255, 255, 255, 0.32);
  }

  [data-theme='dark'] .theme-toggle .knob-sun-image {
    opacity: 0;
    transform: scale(0.72) rotate(-16deg);
  }

  [data-theme='dark'] .theme-toggle .knob-icon-moon {
    opacity: 1;
    transform: scale(1);
    color: #eff5ff;
  }

  [data-theme='dark'] .theme-toggle .knob::before {
    background: radial-gradient(circle at 35% 35%, rgba(255, 255, 255, 0.34), rgba(255, 255, 255, 0.08));
  }

  [data-theme='light'] .theme-toggle .sun {
    opacity: 1;
    transform: translateY(-50%) scale(1);
    filter: saturate(1.02);
  }

  [data-theme='light'] .theme-toggle {
    background:
      radial-gradient(circle at 22% 50%, rgba(10, 143, 166, 0.14), transparent 28%),
      radial-gradient(circle at 78% 50%, rgba(20, 95, 222, 0.14), transparent 34%),
      linear-gradient(90deg, rgba(255, 255, 255, 0.99), rgba(246, 249, 253, 0.95) 48%, rgba(239, 244, 248, 0.97) 100%);
    border-color: color-mix(in srgb, var(--stroke) 96%, rgba(255, 255, 255, 0.78));
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.78),
      0 12px 20px rgba(15, 28, 46, 0.08);
  }

  [data-theme='light'] .theme-toggle .moon {
    opacity: 0.92;
    transform: translateY(-50%) scale(1);
    filter: none;
  }

  [data-theme='light'] .theme-toggle .icon-moon {
    color: #394554;
    stroke-width: 2.15;
    filter: drop-shadow(0 0 3px rgba(32, 41, 54, 0.08));
  }

  [data-theme='light'] .theme-toggle .knob-sun-image {
    opacity: 1;
    transform: scale(1);
  }

  [data-theme='light'] .theme-toggle .knob-icon-moon {
    opacity: 0;
    transform: scale(0.7) rotate(16deg);
  }

  [data-theme='light'] .theme-toggle .knob {
    transform: translateY(-50%);
    background: linear-gradient(145deg, #ffffff, #e8eff7 88%);
    border-color: color-mix(in srgb, var(--accent) 20%, var(--stroke));
    box-shadow:
      0 10px 18px rgba(15, 28, 46, 0.12),
      inset 0 1px 0 rgba(255, 255, 255, 0.78);
  }
</style>
