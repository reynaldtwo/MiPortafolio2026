---
interface Props {
  padded?: boolean;
}

const { padded = true } = Astro.props;
---

<article class:list={['card', { padded }]}>
  <slot />
</article>

<style>
  .card {
    position: relative;
    overflow: hidden;
    background: var(--card);
    color: var(--card-text-1);
    border: 1px solid var(--stroke);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-soft);
    backdrop-filter: blur(7px);
    transition:
      border-color var(--motion-base) var(--motion-ease),
      transform var(--motion-base) var(--motion-ease),
      box-shadow var(--motion-base) var(--motion-ease),
      background var(--motion-base) var(--motion-ease);
  }

  .card::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 50%;
    width: 190%;
    height: 420%;
    background:
      conic-gradient(
        from 110deg at 50% 50%,
        color-mix(in srgb, var(--accent) 56%, var(--card)) 0deg,
        color-mix(in srgb, var(--accent-2) 50%, var(--card)) 120deg,
        color-mix(in srgb, var(--accent-warm) 32%, var(--accent) 68%) 240deg,
        color-mix(in srgb, var(--accent-2) 52%, var(--accent) 48%) 306deg,
        color-mix(in srgb, var(--accent) 56%, var(--card)) 360deg
      ),
      radial-gradient(
        circle at 50% 50%,
        color-mix(in srgb, var(--accent) 24%, transparent) 0%,
        color-mix(in srgb, var(--accent-2) 18%, transparent) 42%,
        color-mix(in srgb, var(--accent) 8%, transparent) 100%
      );
    opacity: 0;
    transform: translate(-50%, -50%) rotate(0deg) scale(1);
    transition:
      opacity var(--motion-base) var(--motion-ease),
      transform 1100ms var(--motion-ease);
    pointer-events: none;
    z-index: 0;
    will-change: transform, opacity;
  }

  .card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      132deg,
      color-mix(in srgb, var(--accent) 16%, transparent),
      color-mix(in srgb, var(--accent-2) 14%, transparent) 54%,
      color-mix(in srgb, var(--accent-warm) 12%, transparent)
    );
    opacity: 0;
    transition: opacity var(--motion-base) var(--motion-ease);
    pointer-events: none;
    z-index: 0;
  }

  .card > * {
    position: relative;
    z-index: 1;
  }

  .card :where(h1, h2, h3, h4, strong, summary) {
    color: var(--card-text-0);
  }

  .card :where(p, li) {
    color: var(--card-text-1);
  }

  .card.padded {
    padding: var(--card-padding);
  }

  :global([data-theme='light']) .card {
    background:
      radial-gradient(circle at 14% 16%, rgba(255, 255, 255, 0.84), transparent 28%),
      linear-gradient(160deg, rgba(255, 255, 255, 0.99), rgba(246, 249, 253, 0.94) 56%, rgba(238, 244, 250, 0.96) 100%),
      var(--card);
    border-color: color-mix(in srgb, var(--stroke) 94%, rgba(255, 255, 255, 0.82));
    box-shadow:
      var(--shadow-soft),
      inset 0 1px 0 rgba(255, 255, 255, 0.9),
      inset 0 -1px 0 rgba(16, 29, 47, 0.04);
    backdrop-filter: blur(10px);
  }

  .card:hover,
  .card:focus-within {
    transform: translateY(-2px);
    border-color: var(--stroke-strong);
    box-shadow: var(--shadow-lift);
    background: color-mix(in srgb, var(--card) 94%, #ffffff 6%);
  }

  :global([data-theme='light']) .card:hover,
  :global([data-theme='light']) .card:focus-within {
    background:
      radial-gradient(circle at 16% 18%, rgba(255, 255, 255, 0.9), transparent 30%),
      linear-gradient(160deg, rgba(255, 255, 255, 1), rgba(247, 250, 254, 0.97) 58%, rgba(240, 246, 251, 0.99) 100%),
      var(--card);
    box-shadow:
      var(--shadow-lift),
      inset 0 1px 0 rgba(255, 255, 255, 0.92),
      inset 0 -1px 0 rgba(16, 29, 47, 0.05);
  }

  .card:hover::before,
  .card:focus-within::before {
    opacity: 0.68;
    transform: translate(-50%, -50%) rotate(34deg) scale(1.06);
  }

  :global([data-theme='light']) .card:hover::before,
  :global([data-theme='light']) .card:focus-within::before {
    opacity: 0.48;
  }

  .card:hover::after,
  .card:focus-within::after {
    opacity: 0.24;
  }

  @media (prefers-reduced-motion: reduce) {
    .card::before {
      transition: none;
    }
  }
</style>
