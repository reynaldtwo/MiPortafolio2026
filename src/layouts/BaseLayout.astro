---
import '../styles/globals.css';
import HeaderPremium from '../components/nav/HeaderPremium.astro';
import Button from '../components/ui/Button.astro';
import { siteConfig } from '../data/site';
import type { Locale } from '../types/content';
import type { I18nDictionary } from '../data/i18n';
import { getAlternateLinks } from '../utils/i18n';

interface Props {
  locale: Locale;
  dict: I18nDictionary;
  title: string;
  description: string;
  pathname: string;
  ogImage?: string;
}

const { locale, dict, title, description, pathname, ogImage = '/images/og-default.svg' } = Astro.props;
const alternates = getAlternateLinks(pathname);
const canonical = new URL(pathname, siteConfig.siteUrl).toString();
const ogImageUrl = new URL(ogImage, siteConfig.siteUrl).toString();
---

<!doctype html>
<html lang={locale} data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0f1b2a" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="en" href={new URL(alternates.en, siteConfig.siteUrl).toString()} />
    <link rel="alternate" hreflang="es" href={new URL(alternates.es, siteConfig.siteUrl).toString()} />
    <link rel="alternate" hreflang="x-default" href={new URL('/en', siteConfig.siteUrl).toString()} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <title>{title}</title>
    <script is:inline>
      (() => {
        try {
          const stored = localStorage.getItem('theme');
          const theme = stored || 'dark';
          document.documentElement.setAttribute('data-theme', theme);
        } catch {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main-content">{dict.skipToContent}</a>
    <HeaderPremium locale={locale} pathname={pathname} dict={dict} />
    <main id="main-content" class="main-content">
      <slot />
    </main>
    <footer class="section">
      <div class="container">
        <div class="footer-shell surface">
          <div class="stack-4">
            <p class="footer-line">{dict.footer.line}</p>
            <p class="footer-muted">{dict.footer.timezone}</p>
          </div>
          <nav class="footer-links" aria-label="Footer links">
            <Button href={siteConfig.contact.email} variant="link">
              Email
            </Button>
            <Button href={siteConfig.contact.linkedin} variant="link" target="_blank">
              LinkedIn
            </Button>
            <Button href={siteConfig.contact.github} variant="link" target="_blank">
              GitHub
            </Button>
            <Button href={siteConfig.contact.playStore} variant="link" target="_blank">
              Play Store
            </Button>
          </nav>
        </div>
      </div>
    </footer>
    <script is:inline>
      (() => {
        const root = document.documentElement;
        const toggle = document.querySelector('[data-theme-toggle]');
        const applyTheme = (theme) => {
          root.setAttribute('data-theme', theme);
          try {
            localStorage.setItem('theme', theme);
          } catch {}
        };
        toggle?.addEventListener('click', () => {
          const next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
          applyTheme(next);
        });

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) entry.target.classList.add('is-visible');
            });
          },
          { threshold: 0.01, rootMargin: '0px 0px 0px 0px' },
        );
        document.querySelectorAll('[data-reveal]').forEach((node) => observer.observe(node));
        window.setTimeout(() => {
          document.querySelectorAll('[data-reveal]:not(.is-visible)').forEach((node) => {
            node.classList.add('is-visible');
          });
        }, 240);

        import('web-vitals')
          .then(({ onLCP, onINP, onCLS }) => {
            const send = (name, value) => {
              window.__portfolioVitals = window.__portfolioVitals || [];
              window.__portfolioVitals.push({ name, value });
            };
            onLCP((metric) => send('LCP', metric.value));
            onINP((metric) => send('INP', metric.value));
            onCLS((metric) => send('CLS', metric.value));
          })
          .catch(() => {});
      })();
    </script>
  </body>
</html>

<style>
  .main-content {
    position: relative;
    z-index: 1;
  }

  .footer-shell {
    padding: clamp(1.05rem, 3vw, 1.45rem) clamp(1rem, 3vw, 1.6rem);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-5);
    flex-wrap: wrap;
  }

  .footer-line {
    color: var(--text-0);
    font-weight: 600;
  }

  .footer-muted {
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }

  .footer-links {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }
</style>
