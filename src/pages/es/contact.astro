---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactLinksSection from '../../components/sections/ContactLinksSection.astro';
import ContactHeroSection from '../../components/sections/ContactHeroSection.astro';
import { getDictionary } from '../../data/i18n';

const locale = 'es';
const dict = getDictionary(locale);
const pathname = '/es/contact/';
---

<BaseLayout
  locale={locale}
  dict={dict}
  title={dict.meta.contact.title}
  description={dict.meta.contact.description}
  pathname={pathname}
  hideFooter={true}
>
  <ContactHeroSection dict={dict} />
  <ContactLinksSection dict={dict} />
</BaseLayout>
