---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/sections/HeroSection.astro';
import PillarsSection from '../../components/sections/PillarsSection.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import { getDictionary } from '../../data/i18n';

const locale = 'en';
const dict = getDictionary(locale);
const pathname = '/en/';
---

<BaseLayout
  locale={locale}
  dict={dict}
  title={dict.meta.home.title}
  description={dict.meta.home.description}
  pathname={pathname}
>
  <HeroSection
    locale={locale}
    title={dict.home.hero.title}
    subline={dict.home.hero.subline}
    constellationTitle={dict.home.hero.constellationTitle}
    paragraph={dict.home.hero.paragraph}
    chips={dict.home.hero.proofChips}
    panelTitle={dict.home.credibility.title}
    highlights={dict.home.credibility.metrics}
    primaryCta={{ label: dict.ctas.viewWork, href: '/en/projects' }}
    secondaryCta={{ label: dict.nav.contact, href: '/en/contact' }}
  />

  <PillarsSection title={dict.home.pillars.title} items={dict.home.pillars.items} />
  <CtaBanner title={dict.home.finalCta.title} primary={{ label: dict.nav.contact, href: '/en/contact' }} />
</BaseLayout>
