---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import ContactLinksSection from '../../components/sections/ContactLinksSection.astro';
import Button from '../../components/ui/Button.astro';
import { getDictionary } from '../../data/i18n';
import { siteConfig } from '../../data/site';

const locale = 'en';
const dict = getDictionary(locale);
const pathname = '/en/contact/';
---

<BaseLayout
  locale={locale}
  dict={dict}
  title={dict.meta.contact.title}
  description={dict.meta.contact.description}
  pathname={pathname}
>
  <section class="section">
    <div class="container stack-5">
      <h1 class="reveal" data-reveal>{dict.contact.hero.title}</h1>
      <p class="section-subtitle reveal" data-reveal>{dict.contact.hero.subline}</p>
      <div class="chip-row reveal" data-reveal>
        <Button href={siteConfig.contact.booking} target="_blank">{dict.ctas.schedule}</Button>
        <Button href={siteConfig.contact.email} variant="secondary">{dict.ctas.email}</Button>
      </div>
    </div>
  </section>
  <ContactLinksSection dict={dict} />
  <CtaBanner
    title={dict.home.finalCta.title}
    primary={{ label: dict.ctas.schedule, href: siteConfig.contact.booking, target: '_blank' }}
    secondary={{ label: dict.ctas.email, href: siteConfig.contact.email }}
  />
</BaseLayout>
